<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">


<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Permisos del rol</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></a></li>
                        <li class="breadcrumb-item"><a href="/admin/roles">Roles</a></li>
                        <li class="breadcrumb-item active">Permisos-Roles</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
<form action="/admin/roles/permisos/guardar" method="post">
<section class="content">
    <div class="card shadow-sm">
        
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><%= role.nombre %></h5>
        </div>

        <div class="card-body">

            <% Object.keys(permisosAgrupados).forEach(tipo => { %>

                <div class="mb-4 border rounded p-3">

                    <!-- Header tipo -->
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0 text-uppercase font-weight-bold">
                            <%= tipo %>
                        </h6>

                        <!-- Check all -->
                        <div class="form-check">
                            <input class="form-check-input check-tipo" 
                                   type="checkbox" 
                                   data-tipo="<%= tipo %>" 
                                   id="check_all_<%= tipo %>">

                            <label class="form-check-label font-weight-bold">
                                Seleccionar todos
                            </label>
                        </div>
                    </div>

                    <div class="row">
                        <% permisosAgrupados[tipo].forEach(p => { %>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input permiso-item tipo-<%= tipo %>" 
                                           type="checkbox" 
                                           <%= p.checked ? 'checked' : '' %>
                                           value="<%= p.id %>" 
                                           name="permiso">

                                    <label class="form-check-label d-flex flex-column">
                                        <span class="fw-bold text-dark">
                                            <%= p.nombre %>
                                        </span>
                                        <span class="text-muted small">
                                            <i class="fas fa-route me-1"></i> <%= p.ruta %>
                                        </span>
                                    </label>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                </div>

            <% }) %>

        </div>

        <div class="card-footer text-right">
            <input type="hidden" value="<%= role.id %>" name="idRole">
            <button type="submit" class="btn btn-success">
                Guardar permisos
            </button>
        </div>

    </div>
</section>
</form>
    
</div>


<!-- MODAL CREAR ROLES -->
<div class="modal fade" id="crearRole" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearRoleLabel">Crear Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/roles/crear" method="POST" id="formCrearRole">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsRole" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresRole"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcion" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcion" name="descripcion" placeholder="" required></textarea>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDITAR ROLES -->
<div class="modal fade" id="editarRole" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editarRoleLabel">Editar Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/roles/actualizar" method="POST" id="formEditarRole">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsRoleEditar" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresRoleEditar"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombreEditar" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombreEditar" name="nombreEditar" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcionEditar" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcionEditar" name="descripcionEditar" placeholder="" required></textarea>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Editar</button>
                <input type="text" class="form-control d-none" id="idRole" name="idRole" placeholder="" required>
                </form>
            </div>
        </div>
    </div>
</div>
<%- partial('../../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>

<script>
   $(document).ready(function () {
        var t = $('#permisos').DataTable({
            columnDefs: [
                {
                    searchable: true,
                    orderable: true,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });

    // Seleccionar todos por tipo
    $('.check-tipo').on('change', function () {
        let tipo = $(this).data('tipo');
        let checked = $(this).is(':checked');

        $('.tipo-' + tipo).prop('checked', checked);
    });

    // Si desmarcan uno, desmarcar el "select all"
    $('.permiso-item').on('change', function () {
        let clases = $(this).attr('class').split(' ');
        let tipoClase = clases.find(c => c.startsWith('tipo-'));

        let tipo = tipoClase.replace('tipo-', '');
        let total = $('.' + tipoClase).length;
        let checked = $('.' + tipoClase + ':checked').length;

        $('#check_all_' + tipo).prop('checked', total === checked);
    });
                //t.buttons().container().appendTo('#inventario_wrapper .col-md-6:eq(0)');   
    });
  function obtenerDato(id){
    $.get(
        '/admin/roles/obtener',
        {id:id},
        function (respuesta) {
            $('#editarRole').modal('show');
            document.getElementById('nombreEditar').value=respuesta.data.nombre;
            document.getElementById('idRole').value=respuesta.data.id;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el Role";
        document.getElementById('mostrarErrores').innerHTML=descErrores;
        $('#errors').show();
        return false;
    });
  }
</script>