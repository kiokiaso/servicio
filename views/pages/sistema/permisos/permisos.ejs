<script>
    $(document).ready(function () {
        var t = $('#permisos').DataTable({
            columnDefs: [
                {
                    searchable: true,
                    orderable: true,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
                //t.buttons().container().appendTo('#inventario_wrapper .col-md-6:eq(0)');   
    });
  function obtenerDato(id){
    $.get(
        '/admin/permisos/obtener',
        {id:id},
        function (respuesta) {
            $('#editarPermiso').modal('show');
            document.getElementById('nombreEditar').value=respuesta.data.nombre;
            document.getElementById('idPermiso').value=respuesta.data.id;
            document.getElementById('rutaEditar').value=respuesta.data.ruta;
            document.getElementById('metodoEditar').value=respuesta.data.metodo;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el permiso";
        document.getElementById('mostrarErrores').innerHTML=descErrores;
        $('#errors').show();
        return false;
    });
  }
</script>