<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">


<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Editar <%=oficina.nombre%> (<%=oficina.razonsocial%>)</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item"><a href="/admin/oficinas">Oficinas</a></li>
                        <li class="breadcrumb-item"><a href="/admin/oficinas/<%=oficina.id%>">Datos Oficinas</a></li>
                        <li class="breadcrumb-item active">Editar</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
              <h3 class="card-title">Oficinas</h3>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-0">
                <table class="table" id="oficinas">
                  <thead>
                    <tr>
                      <th style="width: 10px">Id</th>
                      <th>Nombre</th>
                      <th>Razón social</th>
                      <th>RFC</th>
                      <th>Fecha de creación</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                      <% oficinas.forEach(role=>{ %>
                    <tr>
                      <td><%=oficina.id%></td>
                      <td><a href="/admin/oficinas/<%=oficina.id%>" class="enlaceModificar"><%=oficina.nombre%></a></td>
                      <td><%=oficina.razonsocial%></td>
                      <td><%=oficina.rfc%></td>
                      <td>
                        <%= new Date(oficina.createdAt).toLocaleString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit', 
                            second: '2-digit' 
                        }) %>
                      </td>
                      <td><%
                        if(oficina.activo==1){ %>
                            <a class="btn btn-danger" href="/admin/oficinas/eliminar/<%=oficina.id%>">Desactivar</a>
                            <a class="btn btn-info" href="/admin/oficinas/<%=oficina.id%>">Editar</a>
                        <% }else{ %>
                            <a class="btn btn-success" href="/admin/oficinas/activar/<%=role.id%>">Activar</a>
                        <% } %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
              <div class="card-footer">
                  <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearOficina">
                      Crear Oficina
                  </button>
              </div>
            </div>
          <!-- /.card -->
    </section>
</div>


<!-- MODAL CREAR ROLES -->
<div class="modal fade" id="crearOficina" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearOficinaLabel">Crear Oficina</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/oficinas/crear" method="POST" id="formCrearOficina">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsOficina" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresOficina"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="razonsocial" class="col-sm-2 col-form-label">Razon social*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="razonsocial" name="razonsocial" placeholder="Razón social" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="rfc" class="col-sm-2 col-form-label">RFC*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="rfc" name="rfc" placeholder="Razón social" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="horariolventrada" class="col-sm-2 col-form-label">Horario de entrada lunes a viernes*</label>
                        <div class="col-sm-10">
                            <input type="time" class="form-control" id="horariolventrada" name="horariolventrada" value="09:00" step="1800" required min="07:00" max="18:00">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="horariolvsalida" class="col-sm-2 col-form-label">Horario de salida lunes a viernes*</label>
                        <div class="col-sm-10">
                            <input type="time" class="form-control" id="horariolvsalida" name="horariolvsalida" value="09:00" step="1800" required min="07:00" max="18:00">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="horariosabadoentrada" class="col-sm-2 col-form-label">Horario de entrada sábados*</label>
                        <div class="col-sm-10">
                            <input type="time" class="form-control" id="horariosabadoentrada" name="horariosabadoentrada" value="09:00" step="1800" required min="07:00" max="18:00">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="horariosabadosalida" class="col-sm-2 col-form-label">Horario de salida sábados*</label>
                        <div class="col-sm-10">
                            <input type="time" class="form-control" id="horariosabadosalida" name="horariosabadosalida" value="09:00" step="1800" required min="07:00" max="18:00">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tiemporespuesta" class="col-sm-2 col-form-label">Tiempo de respuesta*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="tiemporespuesta" name="tiemporespuesta" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tiemposolucion" class="col-sm-2 col-form-label">Tiempo de solución*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="tiemposolucion" name="tiemposolucion" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="planificacion" class="col-sm-2 col-form-label">Días antes para la planificación de avisos*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="planificacion" name="planificacion" required>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDITAR ROLES -->
<div class="modal fade" id="editarRole" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editarRoleLabel">Editar Role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/roles/actualizar" method="POST" id="formEditarRole">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsRoleEditar" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresRoleEditar"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombreEditar" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombreEditar" name="nombreEditar" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcionEditar" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcionEditar" name="descripcionEditar" placeholder="" required></textarea>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Editar</button>
                <input type="text" class="form-control d-none" id="idRole" name="idRole" placeholder="" required>
                </form>
            </div>
        </div>
    </div>
</div>
<%- partial('../../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>

<script>
   $(document).ready(function () {
        var t = $('#oficinas').DataTable({
            columnDefs: [
                {
                    searchable: true,
                    orderable: true,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
                //t.buttons().container().appendTo('#inventario_wrapper .col-md-6:eq(0)');   
    });
  function obtenerDato(id){
    $.get(
        '/admin/roles/obtener',
        {id:id},
        function (respuesta) {
            $('#editarRole').modal('show');
            document.getElementById('nombreEditar').value=respuesta.data.nombre;
            document.getElementById('idRole').value=respuesta.data.id;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el Role";
        document.getElementById('mostrarErrores').innerHTML=descErrores;
        $('#errors').show();
        return false;
    });
  }
</script>