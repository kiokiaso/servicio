<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">


<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Plantillas</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item active">Plantillas</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
              <h3 class="card-title">Plantillas</h3>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="plantillas">
                  <thead>
                    <tr>
                      <th style="width: 10px">Id</th>
                      <th>Nombre</th>
                      <th>Tipo Avisos</th>
                      <th>Fecha de creación</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                      <% if(plantillas){ plantillas.forEach(plantilla=>{ %>
                    <tr>
                      <td><%=plantilla.id%></td>
                      <td><a class="enlaceModificar" onclick="obtenerDato(<%=plantilla.id%>)"><%=plantilla.nombre%></a></td>
                      <td><%=plantilla.tipoAvisos.nombre%></td>
                      <td>
                        <%= new Date(plantilla.createdAt).toLocaleString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit', 
                            second: '2-digit' 
                        }) %>
                      </td>
                      <td><%
                        if(plantilla.activo==1){ %>
                            <a class="btn btn-danger" href="/admin/maestros/plantillas/eliminar/<%=plantilla.id%>">Desactivar</a>
                            <a class="btn btn-info" href="/admin/maestros/plantillas/<%=plantilla.id%>">Campos</a>
                        <% }else{ %>
                            <a class="btn btn-success" href="/admin/maestros/plantillas/activar/<%=plantilla.id%>">Activar</a>
                        <% } %>
                      </td>
                    </tr>
                    <% }) }%>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
              <div class="card-footer">
                  <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearPlantilla">
                      Crear Plantilla
                  </button>
              </div>
            </div>
          <!-- /.card -->
    </section>
</div>


<!-- MODAL CREAR ROLES -->
<div class="modal fade" id="crearPlantilla" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearPlantillaLabel">Crear Plantilla</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/maestros/plantillas/crear" method="POST" id="formCrearPlantilla">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsPlantilla" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresPlantilla"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tipoAvisos" class="col-sm-2 col-form-label">Tipo Avisos*</label>
                        <div class="col-sm-10">
                            <select class="form-control" name="tipoAvisos" id="tipoAvisos" >
                                <option value="0">Elige un Tipo de aviso</option>
                                <% tipoAvisos.forEach(aviso=>{ %>
                                  <option value="<%=aviso.id%>"><%=aviso.nombre%></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDITAR ROLES -->
<div class="modal fade" id="editarPlantillas" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearPlantillaEditarLabel">Crear Plantilla</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/admin/maestros/plantillas/actualizar" method="POST" id="formCrearPlantillaEditar">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsPlantillaEditar" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresPlantillaEditar"></div>
                    </div>
                    <div class="form-group row">
                        <label for="nombreEditar" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombreEditar" name="nombreEditar" placeholder="Nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tipoAvisos" class="col-sm-2 col-form-label">Tipo Avisos*</label>
                        <div class="col-sm-10">
                            <select class="form-control" name="tipoAvisosEditar" id="tipoAvisosEditar" >
                                <option value="0">Elige un Tipo de aviso</option>
                                <% tipoAvisos.forEach(aviso=>{ %>
                                  <option value="<%=aviso.id%>"><%=aviso.nombre%></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <input type="text" name="idPlantilla" id="idPlantilla" class="d-none form-control">
                <button type="submit" class="btn btn-primary">Editar</button>
                </form>
            </div>
        </div>
    </div>
</div>
<%- partial('../../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>

<script>
   $(document).ready(function () {
        var t = $('#plantillas').DataTable({
            columnDefs: [
                {
                    searchable: true,
                    orderable: true,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
                //t.buttons().container().appendTo('#inventario_wrapper .col-md-6:eq(0)');   
    });
  function obtenerDato(id){
    $.get(
        '/admin/maestros/plantillas/obtener',
        {id:id},
        function (respuesta) {
            $('#editarPlantillas').modal('show');
            document.getElementById('nombreEditar').value=respuesta.data.nombre;
            document.getElementById('idPlantilla').value=respuesta.data.id;
            document.getElementById('tipoAvisosEditar').value=respuesta.data.tipoAvisos;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado la plantilla";
        document.getElementById('mostrarErroresPlantillaEditar').innerHTML=descErrores;
        $('#errorsPlantillaEditar').show();
        return false;
    });
  }
</script>