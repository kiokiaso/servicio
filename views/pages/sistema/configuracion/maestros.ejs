    function obtenerPrioridad(id){
        $.get(
            '/admin/maestros/prioridades/obtener',
            {id:id},
            function (respuesta) {
                $('#editarPrioridad').modal('show');
                document.getElementById('nombreEditar').value=respuesta.data.nombre;
                document.getElementById('idPrioridad').value=respuesta.data.id;
                document.getElementById('colorEditar').value=respuesta.data.color;
            }
        ).fail(function(res){
            descErrores=descErrores+"No se ha encontrado la prioridad";
            document.getElementById('mostrarErroresPrioridadEditar').innerHTML=descErrores;
            $('#errorsPrioridadEditar').show();
            return false;
        });
    }
