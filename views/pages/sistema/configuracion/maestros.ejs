<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Configuración de los maestros</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item active">Maestros</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
   
    <section class="content">
        <div class="row g-3 p-2">
            <!--INICIO DE PRIORIDAD-->
            <div class="col-12 col-sm-6">
                <div class="card h-100 ">
                    <div class="card-header">
                    <h3 class="card-title">Prioridad</h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- /.card-header -->
                    <div class="card-body p-2">
                        <table class="display table table-bordered table-striped w-100" id="prioridades">
                        <thead>
                            <tr>
                            <th style="width: 10px">Id</th>
                            <th>Nombre</th>
                            <th>Color</th>
                            <th>Fecha de creación</th>
                            <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% prioridades.forEach(prioridad=>{ %>
                            <tr>
                            <td><%=prioridad.id%></td>
                            <td><a class="enlaceModificar" onclick="obtenerPrioridad(<%=prioridad.id%>)"><%=prioridad.nombre%></a></td>
                            <td align="center">
                                <span class="badge" style="background-color: <%=prioridad.color%>;width:20px;height:20px;">
                                </span>
                            </td>
                            <td>
                                <%= new Date(prioridad.createdAt).toLocaleString('es-ES', { 
                                    day: '2-digit', 
                                    month: '2-digit', 
                                    year: 'numeric', 
                                    hour: '2-digit', 
                                    minute: '2-digit', 
                                    second: '2-digit' 
                                }) %>
                            </td>
                            <td><%
                                if(prioridad.activo==1){ %>
                                    <a class="btn btn-danger" href="/admin/maestros/prioridades/eliminar/<%=prioridad.id%>">Desactivar</a>
                                <% }else{ %>
                                    <a class="btn btn-success" href="/admin/maestros/prioridades/activar/<%=prioridad.id%>">Activar</a>
                                <% } %>
                            </td>
                            </tr>
                            <% }) %>
                        </tbody>
                        </table>
                    </div>
                    <!-- /.card-body -->
                    <div class="card-footer">
                        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearPrioridad">
                            Crear Prioridad
                        </button>
                    </div>
                </div>
            </div>
            <!-- / FIN DE PRIORIDAD -->
            <!-- / INICIO DE CONTACTO -->
            <div class="col-12 col-sm-6">
                <div class="card h-100 ">
                    <div class="card-header">
                    <h3 class="card-title">Tipo de Contacto</h3>
                    </div>
                    <!-- /.card-header -->
                    <!-- /.card-header -->
                    <div class="card-body p-2">
                        <table class="display table table-bordered table-striped w-100" id="tiposContacto">
                        <thead>
                            <tr>
                            <th style="width: 10px">Id</th>
                            <th>Nombre</th>
                            <th>Fecha de creación</th>
                            <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% tiposContacto.forEach(contacto=>{ %>
                            <tr>
                            <td><%=contacto.id%></td>
                            <td><a class="enlaceModificar" onclick="obtenerTipoContacto(<%=contacto.id%>)"><%=contacto.nombre%></a></td>
                            <td>
                                <%= new Date(contacto.createdAt).toLocaleString('es-ES', { 
                                    day: '2-digit', 
                                    month: '2-digit', 
                                    year: 'numeric', 
                                    hour: '2-digit', 
                                    minute: '2-digit', 
                                    second: '2-digit' 
                                }) %>
                            </td>
                            <td><%
                                if(contacto.activo==1){ %>
                                    <a class="btn btn-danger" href="/admin/maestros/tipos-contacto/eliminar/<%=contacto.id%>">Desactivar</a>
                                <% }else{ %>
                                    <a class="btn btn-success"
                                        href="/admin/maestros/tipos-contacto/activar/<%=contacto.id%>">Activar</a>
                                <% } %>
                            </td>
                            </tr>
                            <% }) %>
                        </tbody>
                        </table>
                    </div>
                    <!-- /.card-body -->
                    <div class="card-footer">
                        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearTipoContacto">
                            Crear Tipo Contacto
                        </button>
                    </div>
                </div>
            </div>
            <!-- / FIN DE CONTACTO -->
        </div>
    </section>
