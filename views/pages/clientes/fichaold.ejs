    <script>
        $(document).ready(function () {
            document.getElementById('btn-agregar-serie').addEventListener('click', function () {
                let input = document.createElement('input');
                input.type = 'text';
                input.name = 'series[]';
                input.className = 'form-control';
                document.getElementById('lista-series').appendChild(input);
            });
            var table = $('#articulos').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/almacen/articulos/tabla",
                    "type": "GET"
                },
                rowId: 'id',
                stateSave: true,
                columns: [
                    {
                        data: null,
                        render: function (data, type, row) {
                            return `<a href="/almacen/articulos/${row.id}">
                                ${row.codigo}
                            </a>`;
                        }
                    },
                    { data: 'descripcion' },
                    { data: 'marca' },
                    { data: 'modelo' },
                    { data: 'tipo' },
                    { data: 'garantia' },
                    { data: 'preciopublico' },
                ],
                columnDefs: [
                    {
                        searchable: false,
                        orderable: false,
                        targets: 0,
                    },
                ],
                scrollX: true,
                scrollCollapse: true,
                fixedColumns: { leftColumns: 2 },
                order: [[0, 'asc']],
            });
        });
        function cambiarSeries() {
            if (document.getElementById("tipo").value == "COMPRA") {
                document.getElementById("comprarSeries").className = "form-group row"
                document.getElementById("venderSeries").className = "form-group row d-none"
            } else {
                document.getElementById("comprarSeries").className = "form-group row d-none"
                document.getElementById("venderSeries").className = "form-group row "
            }
        }
        function obtenerSeries(id) {
            $.get(
                '/almacen/articulos/obtener/series',
                { id: id },
                function (respuesta) {
                    let listaSeries = Array.isArray(respuesta.data) ? respuesta.data : [respuesta.data];

                    $('#verSeries').modal('show');
                    let tablaHtml = `
                    <table class="table table-hover table-striped mb-0">
                        <thead class="thead-dark">
                            <tr>
                                <th class="border-0">ID</th>
                                <th class="border-0">Número de Serie</th>
                                <th class="border-0 text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                `;
                    listaSeries.forEach(item => {
                        // Formato vistoso para el campo 'usado'
                        let badgeEstado = item.usado === "INSTALADO"
                            ? '<span class="badge badge-pill badge-warning"><i class="fas fa-history"></i> Instalado</span>'
                            : '<span class="badge badge-pill badge-success"><i class="fas fa-check"></i> Disponible</span>';

                        tablaHtml += `
                            <tr>
                                <td class="align-middle font-weight-bold text-muted">#${item.id}</td>
                                <td class="align-middle">
                                    <span class="text-primary"><i class="fas fa-barcode mr-2"></i>${item.serie}</span>
                                </td>
                                <td class="align-middle text-center">
                                    ${badgeEstado}
                                </td>
                            </tr>
                        `;
                    });


                    tablaHtml += `
                        </tbody>
                    </table>
                `;

                    $('#contenedorSeries').html(tablaHtml);
                }
            ).fail(function (res) {
                descErrores = descErrores + "No se ha encontrado el puesto";
                document.getElementById('mostrarErroresAutoEditar').innerHTML = descErrores;
                $('#errorsAutoEditar').show();
                return false;
            });
        }
    </script>