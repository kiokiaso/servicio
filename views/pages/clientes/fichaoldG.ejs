  }*/

  // 4. Geocodificación (Dirección a Coordenadas)
  function geocodeAddress(address) {
    if (!address) return;
    const geocoder = L.Control.Geocoder.nominatim();

    geocoder.geocode(address, function(results) {
            if (results.length > 0) {
                const res = results[0];
                map.setView(res.center, 15);
                marker.setLatLng(res.center);
                saveNewCoords(res.center.lat, res.center.lng);
            }
        });
    }
    async function saveNewCoords(lat, lng) {
        const status = document.getElementById('map-status');
        if (!status) return;

        status.className = "badge badge-warning text-white";
        status.innerText = "Guardando...";

        try {
        const response = await fetch('/cliente/update-coordinates', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
            id: "<%= cliente.id %>", 
            coordenadas: `${lat},${lng}` 
            })
        });

        if(response.ok) {
            status.className = "badge badge-success text-white";
            status.innerText = "Actualizado";
            setTimeout(() => { status.innerText = "Sincronizado"; }, 2000);
        }
        } catch (e) {
        status.className = "badge badge-danger text-white";
        status.innerText = "Error de conexión";
        }
    }
</script>
