<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
<link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">
<style>
  :root { --crm-primary: #2c3e50; --crm-accent: #3498db; }
  body { background-color: #f8f9fc; font-family: 'Inter', sans-serif; }
  .card { border: none; border-radius: 12px; transition: all 0.3s; }
  .shadow-crm { box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1) !important; }
  .nav-tabs-custom .nav-link { border: none; color: #a1a1a1; font-weight: 600; padding: 1rem 1.5rem; }
  .nav-tabs-custom .nav-link.active { color: var(--crm-accent); background: transparent; border-bottom: 3px solid var(--crm-accent); }
  #mainMap { height: 400px; border-radius: 0 0 12px 12px; z-index: 1; }
  .info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #95a5a6; margin-bottom: 2px; }
  .info-value { font-weight: 600; color: var(--crm-primary); }
  /* Estilos para que el foreach se vea fluido */
    .contact-item {
        border-color: #f0f2f5 !important;
        transition: all 0.2s ease-in-out;
    }
    
    .contact-item:hover {
        border-color: #4e73df !important;
        background-color: #f8faff !important;
        transform: scale(1.01);
        z-index: 2;
    }

    .hover-shadow:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
    }

    .line-height-1 {
        line-height: 1.2;
    }

    .bg-soft-primary {
        background-color: rgba(78, 115, 223, 0.1) !important;
    }

    /* Ajuste para móviles: si la pantalla es pequeña, ocultar ubicación o ajustar botones */
    @media (max-width: 576px) {
        .contact-item {
            flex-direction: column;
            align-items: flex-start !important;
        }
        .contact-item > .d-flex:last-child {
            border-left: none !important;
            border-top: 1px solid #eee;
            width: 100%;
            margin-left: 0 !important;
            padding-left: 0 !important;
            padding-top: 10px;
            margin-top: 10px;
            justify-content: flex-end;
        }
    }

    #datSeries {
        box-shadow: 2px 2px 8px 0 rgba(0,0,0,.2);
        height: auto;
        /*position: absolute;*/
        top: 45px;
        z-index: 9999;
        width: 206px;
        text-align: center;
        background-color: #e8e8e8;
    }
    #datSeries .suggest-element {
        background-color: #0067c6;
        border-top: 1px solid #d6d4d4;
        cursor: pointer;
        padding: 8px;
        width: 100%;
        float: left;
        color:#FFF;
        border-radius: 0px 0px 5px 5px;

    }
</style>
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <div class="float-left">
                        <h3 class="font-weight-bold text-dark mb-0" id="clienteRazonSocial">
                            <i class="nav-icon bi-building"></i> <%=cliente.razonsocial%>
                        </h3>
                    </div>
                    <div class="float-left pl-3">
                        <span class="badge badge-pill <%= cliente.activo ? 'badge-success' : 'badge-danger' %> px-3 py-2">
                            <%= cliente.activo ? '● Cuenta Activa' : '● Inactiva' %>
                        </span>
                        <% if(cliente.moroso) { %>
                            <div class="text-danger small mt-1 font-weight-bold" id="activoMoroso"><i class="fas fa-exclamation-circle"></i> MOROSO</div>
                        <% }else{%>
                            <div class="text-danger small mt-1 font-weight-bold" id="activoMoroso"></div>
                         <%} %>
                    </div>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="/clientes">Clientes</a></li>
                        <li class="breadcrumb-item active">Ficha</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
        <% }) %>
    <div class="container-fluid py-4">
        <div class="row">
            <!-- Columna Izquierda: Información y Pestañas -->
            <div class="col-lg-8">
            <div class="card shadow-crm mb-4">
                <ul class="nav nav-tabs nav-tabs-custom" id="crmTab" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#general">Perfil General</a></li>
                <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#ubicaciones">Ubicaciones</a></li>
                <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#contactos">Contactos</a></li>
                <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#equipos">Equipos </a></li>
                </ul>
                
                <div class="tab-content p-4">
                    <!-- PESTAÑA GENERAL -->
                    <div class="tab-pane fade show active" id="general">
                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <div class="info-label text-accent">código</div>
                                <div class="info-value"  id="clienteCodigo"><%= cliente.codigo %></div>
                            </div>
                            <div class="col-md-4 mb-4">
                                <div class="info-label text-accent">RFC</div>
                                <div class="info-value"  id="clienteRFC"><%= cliente.rfc %></div>
                            </div>
                            <div class="col-md-4 mb-4" id="clienteTipo">
                                <div class="info-label text-accent">Tipo de Cliente</div>
                                <% if(cliente.esPolizaForanea){ %>
                                    <span class="badge badge-light border text-danger">Póliza entre exi</span> <%=cliente.oficina.nombre%>
                                <% }else{
                                    if(cliente.tipo=="ARRENDAMIENTO"){%>
                                        <span class="badge-light border text-primary">ARRENDAMIENTO</span>
                                    <%}if(cliente.tipo=="POLIZA"){%>
                                        <span class="badge badge-light border text-success">Póliza de servicio</span>
                                    <%} if(cliente.tipo=="TYM"){%>
                                        <span class="badge badge-light border text-secondary">TYM</span>
                                    <%}%>  
                                <% } %>
                                <!--<div class="badge badge-light border text-primary" id="clienteTipo"><%= cliente.tipo %></div>-->
                            </div>
                            <div class="col-12 mb-4">
                                <div class="info-label text-accent">Dirección Fiscal</div>
                                <div class="info-value" id="clienteDireccion"><%= cliente.direccion %></div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="info-label text-accent">Teléfono</div>
                                <div class="info-value" id="clienteTelefono"><i class="fas fa-phone-alt mr-2 text-muted"></i><%= cliente.telefono %></div>
                            </div>
                            <div class="col-md-8 mb-3">
                                <div class="info-label text-accent">Correo Electrónico</div>
                                <div class="info-value text-primary" id="clienteEmail"><i class="far fa-envelope mr-2 text-muted"></i><%= cliente.email %></div>
                            </div>
                        </div>
                        <hr>
                        <div class="row pt-2">
                            <div class="col-md-6">
                                <div class="info-label">Horario de Atención</div>
                                <div class="info-value font-weight-normal" id="clienteHorario"><i class="far fa-clock mr-1 text-muted"></i> <%= cliente.horario || 'No definido' %></div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Ruta Asignada</div>
                                <div class="info-value text-info" id="clienteRuta"><i class="fas fa-truck mr-1"></i> <%= cliente.ruta.nombre %></div>
                            </div>
                        </div><hr>
                        <div class="row pt-2">
                            <div class="col-md-6">
                                <% if(!cliente.esPolizaForanea){ %>
                                    <button class="btn btn-warning" onclick="editar()">Editar</button>
                                <% } %>
                            </div>
                            <div class="col-md-6">
                                
                            </div>
                        </div>
                    </div>

                    <!-- PESTAÑA UBICACIONES -->
                    <div class="tab-pane fade" id="ubicaciones">
                        <div class="row align-items-center mb-4">
                            <div class="col-md-3">
                                <% if(!cliente.esPolizaForanea){ %>
                                    <button class="btn btn-success" onclick="maUbicacion()">Crear ubicación</button>
                                <% } %>
                            </div>
                            <div class="col-md-3">
                                <h5 class="text-secondary font-weight-bold mb-0">Ubicaciones</h5>
                                <span class="badge badge-pill badge-light border text-muted">
                                    <span id="ubicaciones-count"><%= cliente.ubicaciones.length %></span> Ubicaciones en total
                                </span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0 text-muted">
                                            <!-- Icono de lupa nativo o SVG -->
                                            <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-search" fill="currentColor" xmlns="http://www.w3.org">
                                            <path fill-rule="evenodd" d="M10.442 10.442a1 1 0 0 1 1.415 0l3.85 3.85a1 1 0 0 1-1.414 1.415l-3.85-3.85a1 1 0 0 1 0-1.415z"/>
                                            <path fill-rule="evenodd" d="M6.5 12a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zM13 6.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0z"/>
                                            </svg>
                                        </span>
                                    </div>
                                    <input type="text" id="searchUbicaciones" class="form-control border-left-0 pl-0" placeholder="Filtrar por nombre o ruta...">
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-borderless table-hover" id="tablaUbicaciones">
                                <thead class="text-muted small border-bottom">
                                    <tr>
                                        <th>SITIO</th>
                                        <th>HORARIO</th>
                                        <th>RUTA</th>
                                        <th>OFICINA POLIZA</th>
                                        <th class="text-right">ACCIONES</th>
                                    </tr>
                                </thead>
                                <tbody>
                                <% cliente.ubicaciones.forEach(u => {
                                    let mostrarFila = false;
                                    let mostrarBotones = false;
                                    if (cliente.esPolizaForanea) {
                                        // Si es foránea, solo mostramos si la oficina de atención coincide con la sesión
                                        if (u.oficinaAtencion && u.oficinaAtencion.id == oficinaElegida.id) {
                                            mostrarFila = true;
                                        }
                                        if (u.oficinaAtencion && u.oficinaAtencion.id != oficinaElegida.id) {
                                            mostrarBotones = true;
                                        }
                                    } else {
                                        // Si no es foránea, mostramos todas
                                        mostrarFila = true;
                                        mostrarBotones=true
                                    }
                                    if(u.activo==0){
                                        mostrarFila=false;
                                    }
                                    if(mostrarFila){ %>   
                                    <tr class="border-bottom">
                                        <td>
                                            <div class="font-weight-bold mb-0"><%= u.nombre %></div>
                                            <small class="text-muted"><%= u.direccion %></small>
                                        </td>
                                        <td class="align-middle">
                                            <span class="badge badge-pill badge-<%= u.activo==1 ? 'soft-success' : 'soft-secondary' %>">
                                            <%= u.horario %>
                                            </span>
                                        </td>
                                        <td class="align-middle info-value text-info">
                                            <i class="fas fa-truck mr-1"></i> <%= u.ruta.nombre %>
                                        </td>
                                        <td class="align-middle text-muted">
                                            <% if(u.oficinaAtencion){ %>
                                                <%=u.oficinaAtencion.nombre%>
                                            <%}else{%>
                                                -
                                            <%} %>
                                        </td>
                                        <td class="text-right align-middle" style="white-space: nowrap; width: 1%;">
                                            <% if(mostrarBotones){  %>
                                                    
                                                    <button class="btn btn-sm btn-light shadow-sm btnEliminar" data-coord='<%= u.coordenadas %>' data-nombre='<%= u.nombre %>' data-direccion='<%= u.direccion %>' data-id='<%= u.id %>'>
                                                        <i class="fas fa-trash text-danger"></i>
                                                    </button>
                                                
                                            <%} %>
                                            <button class="btn btn-sm btn-light shadow-sm btnEditar" data-coord='<%= u.coordenadas %>' data-nombre='<%= u.nombre %>' data-direccion='<%= u.direccion %>' data-id='<%= u.id %>'>
                                                <i class="fas fa-edit text-warning"></i>
                                            </button>
                                            <button class="btn btn-sm btn-light shadow-sm btnMapa" data-coord='<%= u.coordenadas %>' data-nombre='<%= u.nombre %>' data-direccion='<%= u.direccion %>' data-id='<%= u.id %>'>
                                                <i class="fas fa-map-pin text-primary"></i>
                                            </button>
                                        </td>
                                    </tr>
                                        
                                <%} }) %> 
                                </tbody>
                            </table>
                        </div>
                        <!-- Mensaje de no resultados -->
                        <div id="noResultsUbicacion" class="text-center py-5 d-none">
                            <p class="text-muted">No se encontraron ubicaciones que coincidan con la búsqueda.</p>
                        </div>
                    </div>

                    <!-- PESTAÑA CONTACTOS -->
                    <div class="tab-pane fade" id="contactos">
                        <div class="row align-items-center mb-4">
                            <div class="col-md-3">
                                    <button class="btn btn-success" onclick="maContacto()">Crear Contacto</button>
                            </div>
                            <div class="col-md-3">
                                <h5 class="text-secondary font-weight-bold mb-0">Contactos</h5>
                                <span class="badge badge-pill badge-light border text-muted">
                                    <span id="contactos-count"><%= cliente.contactos.length %></span> Contactos en total
                                </span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0 text-muted">
                                            <!-- Icono de lupa nativo o SVG -->
                                            <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-search" fill="currentColor" xmlns="http://www.w3.org">
                                            <path fill-rule="evenodd" d="M10.442 10.442a1 1 0 0 1 1.415 0l3.85 3.85a1 1 0 0 1-1.414 1.415l-3.85-3.85a1 1 0 0 1 0-1.415z"/>
                                            <path fill-rule="evenodd" d="M6.5 12a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zM13 6.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0z"/>
                                            </svg>
                                        </span>
                                    </div>
                                    <input type="text" id="searchContactos" class="form-control border-left-0 pl-0" placeholder="Filtrar por nombre o email...">
                                </div>
                            </div>
                        </div>
                        
                        <div class="card shadow-crm">
                            <div class="card-body p-1">
                                <div class="list-group list-group-flush" id="listaContactos">
                                    <%
                                    let contactosVisibles;
                                    if(cliente.esPolizaForanea){
                                        const idsConOficina = cliente.ubicaciones.filter(u =>{
                                            const idOficinaAtencion = (u.oficinaAtencion && u.oficinaAtencion.id) ? u.oficinaAtencion.id : u.oficinaAtencion;
                                            return idOficinaAtencion && idOficinaAtencion == oficinaElegida.id;
                                        }).map(u => u.id.toString());
                                        contactosVisibles = cliente.contactos.filter(c => {
                                            const idUbicacionContacto = (c.ubicacion && c.ubicacion.id) ? c.ubicacion.id : c.ubicacion;
                                            return idUbicacionContacto && idsConOficina.includes(idUbicacionContacto.toString());
                                        });
                                    }else{
                                        contactosVisibles=cliente.contactos;
                                    }
                                    contactosVisibles.forEach(c => {
                                        if(c.activo==1){ %>
                                        <div class="contenedor-busqueda contacto-card"> 
                                            <div class="contact-item p-3 mb-2 bg-white border rounded shadow-sm d-flex align-items-center justify-content-between hover-shadow transition-all " data-searchcont="<%=c.nombre.toLowerCase()%> <%=c.email.toLowerCase()%>" id="lista<%=c.id%>">
                                                <div class="d-flex align-items-center overflow-hidden">
                                                    <!-- Avatar Circular con Inicial o Icono -->
                                                    <div class="avatar-sm d-flex align-items-center justify-content-center rounded-circle bg-soft-primary text-primary mr-3 shadow-none" 
                                                        style="width: 48px; height: 48px; min-width: 48px; background-color: #eef2ff; border: 1px solid #e0e7ff;">
                                                        <i class="fas fa-user-tie fa-lg"></i>
                                                    </div>

                                                    <!-- Cuerpo de Información -->
                                                    <div class="line-height-1">
                                                        <div class="d-flex align-items-center mb-1">
                                                            <h6 class="font-weight-bold mb-0 mr-2 text-dark"><%=c.nombre%></h6>
                                                            <span class="badge badge-pill bg-light text-muted border px-2 py-1" style="font-size: 10px; font-weight: 500;">
                                                                <i class="fas fa-id-badge mr-1 text-primary"></i> <%=c.tipocontacto.nombre || 'S/P'%>
                                                            </span>
                                                        </div>
                                                        
                                                        <!-- Fila de Datos Secundarios -->
                                                        <div class="d-flex flex-wrap align-items-center text-muted" style="font-size: 12px; gap: 12px;">
                                                            <span class="d-flex align-items-center">
                                                                <i class="fas fa-envelope-open-text mr-1 text-info"></i> <%=c.email%>
                                                            </span>
                                                            <span class="d-flex align-items-center">
                                                                <i class="fas fa-phone-alt mr-1 text-success"></i> <%=c.telefono%>
                                                            </span>
                                                            <span class="d-flex align-items-center w-100 mt-1">
                                                                <i class="fas fa-map-marker-alt mr-1 text-danger"></i> 
                                                                <span class="text-truncate" style="max-width: 250px;"><%=c.ubicacion.nombre || 'Ubicación no definida'%></span>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Botones de Acción Minimalistas -->
                                                <div class="d-flex border-left pl-3 ml-3" style="gap: 8px;">
                                                    <button class="btn btn-sm btn-outline-warning border-0 rounded-circle btnEditarContacto" 
                                                            data-id="<%=c.id%>" title="Editar contacto" style="width: 32px; height: 32px; padding: 0;">
                                                        <i class="fas fa-pen"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger border-0 rounded-circle btnEliminarContacto" 
                                                            data-id="<%=c.id%>" title="Eliminar contacto" style="width: 32px; height: 32px; padding: 0;">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    <% } })  %>
                                </div>
                                <!-- Mensaje de no resultados -->
                                <div id="noResultsContacto" class="text-center py-5 d-none">
                                    <p class="text-muted">No se encontraron contactos que coincidan con la búsqueda.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PESTAÑA EQUIPOS TÉCNICOS -->
                    <div class="tab-pane fade" id="equipos" role="tabpanel">
                        <!-- Barra de Herramientas: Título y Buscador -->
                        <div class="row align-items-center mb-4">
                            <div class="col-md-3">
                                    <button class="btn btn-success" onclick="maEquipo()">Crear Equipo</button>
                            </div>
                            <div class="col-md-4">
                                <h5 class="text-secondary font-weight-bold mb-0">Inventario Instalado</h5>
                                <span class="badge badge-pill badge-light border text-muted">
                                    <span id="equipos-count"><%= cliente.equipos.length %></span> Equipos en total
                                </span>
                            </div>
                            <div class="col-md-5 mt-3 mt-md-0">
                                <div class="input-group shadow-sm">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white border-right-0 text-muted">
                                            <!-- Icono de lupa nativo o SVG -->
                                            <svg width="1em" height="1em" viewBox="0 0 16 16" class="bi bi-search" fill="currentColor" xmlns="http://www.w3.org">
                                            <path fill-rule="evenodd" d="M10.442 10.442a1 1 0 0 1 1.415 0l3.85 3.85a1 1 0 0 1-1.414 1.415l-3.85-3.85a1 1 0 0 1 0-1.415z"/>
                                            <path fill-rule="evenodd" d="M6.5 12a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zM13 6.5a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0z"/>
                                            </svg>
                                        </span>
                                    </div>
                                    <input type="text" id="searchEquipos" class="form-control border-left-0 pl-0" placeholder="Filtrar por serie, marca o modelo...">
                                </div>
                            </div>
                        </div>

                        <!-- Grid de Equipos -->
                        <div class="row" id="equiposGrid">
                            <%
                            let equiposVisibles;
                                    if(cliente.esPolizaForanea){
                                        const idsConOficina = cliente.ubicaciones.filter(u =>{
                                            const idOficinaAtencion = (u.oficinaAtencion && u.oficinaAtencion.id) ? u.oficinaAtencion.id : u.oficinaAtencion;
                                            return idOficinaAtencion && idOficinaAtencion == oficinaElegida.id;
                                        }).map(u => u.id.toString());
                                        equiposVisibles = cliente.equipos.filter(c => {
                                            const idUbicacionContacto = (c.ubicacion && c.ubicacion.id) ? c.ubicacion.id : c.ubicacion;
                                            return idUbicacionContacto && idsConOficina.includes(idUbicacionContacto.toString());
                                        });
                                    }else{
                                        equiposVisibles=cliente.equipos;
                                    } 
                            equiposVisibles.forEach(function(e) { %>
                                <div class="col-md-6 col-xl-4 mb-4 equipo-card" id="equipo<%=e.id%>"
                                    data-search="<%= e.numeroserie.toLowerCase() %> <%= e.articulo.marca.toLowerCase() %> <%= e.articulo.modelo.toLowerCase() %> <%= e.ubicacion.nombre.toLowerCase() %>">
                                    <div class="card h-100 shadow-sm border-0 border-left-accent shadow-hover">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between mb-3">
                                                <div>
                                                <div class="info-label">Número de Serie</div>
                                                <div class="h6 font-weight-bold text-primary mb-0"><%= e.numeroserie %></div>
                                                </div>
                                                <div class="text-muted">
                                                <!-- Icono de CPU/Hardware -->
