// INIT
    window.addEventListener('load', initMap);
    async function initMap() {
        geocoder = new google.maps.Geocoder();
        let lat = 19.026257126757454;
        let lng = -98.19270045091669;
        const coordsInput = document.getElementById('coordenadasCliente');
        const coords = coordsInput ? coordsInput.value : "<%= cliente.coordenadas %>";
        // SI EXISTEN COORDENADAS
        if (coords && coords.includes(',')) {
            const parts = coords.split(',');
            lat = parseFloat(parts[0]);
            lng = parseFloat(parts[1]);
        }
        const center = { lat, lng };
        // MAPA
        map = new google.maps.Map(document.getElementById("mainMap"), {
            zoom: 14,
            center: center,
            mapId:'58e3a475509362304b85a24c',
            mapTypeControl: false,
            streetViewControl: false
        });
        // MARCADOR MODERNO (2026)
        marker = new google.maps.marker.AdvancedMarkerElement({
            map: map,
            position: center,
            gmpDraggable: true
        });
        // DRAG EVENT
        marker.addListener("dragend", (event) => {
            const pos = event.latLng;
            updateCoords(pos.lat(), pos.lng());
        });
        // SI NO HAY COORDENADAS → GEOCODING
        if (!coords || coords === "") {
            geocodeAddress("<%= cliente.direccion %>");
        }   
        // TRAZAR RUTA
        //trazarRuta();
    }

    function setUbicacionMapa(id, coordenadas, direccion,nombre) {
        document.getElementById("nombreUbicacion").innerText=nombre;
        currentType = 'ubicacion';
        document.getElementById('tipoCoordenada').value="ubicacion"
        currentId = id;
        if (coordenadas && coordenadas.includes(',')) {
            const parts = coordenadas.split(',');
            const lat = parseFloat(parts[0]);
            const lng = parseFloat(parts[1]);
            const pos = { lat, lng };
            marker.position = pos;
            map.setCenter(pos);
        } else {
            geocodeAddress(direccion);
        }
    }
    function normalizarDireccion(address) {
        if (!address) return "";
        return address
            .replace(/cp\s*\d+/i, '')
            .replace(/-/g, ' ')
            .replace(/\s+/g, ' ')
            .trim();
    }
    function geocodeAddress(address) {
        if (!address) return;
        const cleanAddress = normalizarDireccion(address);
        geocoder.geocode({ address: cleanAddress }, function(results, status) {
            console.log("STATUS:", status);
            if (status === "OK") {
                const location = results[0].geometry.location;
                map.setCenter(location);
                marker.position = location;
                updateCoords(location.lat(), location.lng());
            } else {
                console.warn("Fallback geocoder");
                geocoder.geocode({ address: "cdmx, México" }, function(res2, status2) {
                    if (status2 === "OK") {
                        const loc = res2[0].geometry.location;
                        map.setCenter(loc);
                        marker.position = loc;
                    }
                });
            }
        });
    }
    function updateCoords(lat, lng) {
        console.log("Nuevas coordenadas:", lat, lng);
        const coords = `${lat},${lng}`;
        const input = document.getElementById('coordenadasCliente');
        if (input) input.value = coords;
        
        saveNewCoords(lat, lng);
    }
    async function saveNewCoords(lat, lng) {
        const status = document.getElementById('map-status');
        if (status) {
            status.className = "badge badge-warning text-white";
            status.innerText = "Guardando...";
        }
        try {
            const url = currentType === 'cliente'
            ? '/clientes/actualizar-coordenadas'
            : '/clientes/ubicacion/actualizar-coordenadas';
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    id: currentId,
                    coordenadas: `${lat},${lng}`
                })
            });
            if (response.ok && status) {
                status.className = "badge badge-success text-white";
                status.innerText = "Actualizado";
                setTimeout(() => status.innerText = "Sincronizado", 2000);
            }
        } catch (e) {
            console.error(e);
            if (status) {
                status.className = "badge badge-danger text-white";
                status.innerText = "Error";
            }
        }
    }
    let lastRouteRequest = 0;
    async function trazarRuta() {
        const ahora = Date.now();
        // Bloquea la petición si se hizo una hace menos de 10 segundos
        if (ahora - lastRouteRequest < 10000) { 
            console.warn("Espera un poco para actualizar la ruta");
            return; 
        }
        lastRouteRequest = ahora;
        if (!puntos || puntos.length < 2) return;
        const url = "https://routes.googleapis.com/directions/v2:computeRoutes";
        const body = {
            origin: {
            location: {
                latLng: {
                latitude: puntos[0].lat,
                longitude: puntos[0].lng
                }
            }
            },
            destination: {
            location: {
                latLng: {
                latitude: puntos[puntos.length - 1].lat,
                longitude: puntos[puntos.length - 1].lng
                }
            }
            },
            intermediates: puntos.slice(1, -1).map(p => ({
            location: {
                latLng: {
                latitude: p.lat,
                longitude: p.lng
                }
            }
            })),
            travelMode: "DRIVE",
            //routingPreference: "TRAFFIC_AWARE"
        };
        try {
            const res = await fetch(url, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Goog-Api-Key": "AIzaSyCax07nLMeUuGzvQk5HbMSc8chV61aoe7w",
                "X-Goog-FieldMask": "routes.polyline.encodedPolyline,routes.distanceMeters,routes.duration" 
            },
            body: JSON.stringify(body)
            });
            const data = await res.json();
            if (!data.routes) {
            console.error("No se pudo calcular ruta");
            return;
            }
            const encodedPolyline = data.routes[0].polyline.encodedPolyline;
            const decodedPath = google.maps.geometry.encoding.decodePath(encodedPolyline);
            new google.maps.Polyline({
            path: decodedPath,
            geodesic: true,
            strokeColor: "#3498db",
            strokeOpacity: 1.0,
            strokeWeight: 5
            }).setMap(map);
        } catch (e) {
            console.error("Error en ruta:", e);
        }
    }



