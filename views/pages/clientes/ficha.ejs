    function buscarSeries(){
        var numero = document.getElementById("numeroserie").value;
        var oficina = document.getElementById("oficinaEquipo").value;
        var contenido="<div><strong>Clic a la serie para elegirla</strong></div>";
        if(numero.length>2){
            $.get(
                '/almacen/series/buscar',
                { numero: numero,oficina },
                function (res) {
                    res.series.forEach(s => {
                        contenido = contenido + `<div style="cursor:pointer"><a class="suggest-element" data="${s.id}" serie="${s.serie}"  id="${s.id}" marca="${s.articulo.marca}" modelo="${s.articulo.modelo}" articulo="${s.articulo.id}" descripcion="${s.articulo.descripcion}" tipocolor="${s.articulo.tipocolor}" tamano="${s.articulo.tamano}" >${s.serie}</a></div>`;

                    });
                    $('#datSeries').fadeIn(1000).html(contenido);
                    $('.suggest-element').on('click', function () {
                                //Obtenemos la id unica de la sugerencia pulsada
                        var id = $(this).attr('id');
                        var marca = $(this).attr('marca');
                        var modelo = $(this).attr('modelo');
                        var articulo = $(this).attr('articulo');
                        var descripcion = $(this).attr('descripcion');
                        var tipocolor = $(this).attr('tipocolor');
                        var tamano = $(this).attr('tamano');
                        var serie = $(this).attr('serie');
                        $('#numeroserie').val($('#' + id).attr('data'));
                                    //Hacemos desaparecer el resto de sugerencias
                        document.getElementById('datSeries').innerHTML = "";
                        document.getElementById('datSeries').style = 'display:none';
                                    //alert('Has seleccionado el '+id+' '+$('#'+id).attr('data'));
                        $('#serieId').val(id);
                        $('#articuloId').val(articulo);
                        $('#marca').val(marca);
                        $('#modelo').val(modelo);
                        $('#descripcion').val(descripcion);
                        $('#tipocolor').val(tipocolor);
                        $('#tamano').val(tamano);
                        $('#numeroserie').val(serie);
                        //$('#idArticulo').trigger('change'); 
                    });
            }).fail(function (res) {
                document.getElementById('datSeries').innerHTML = "";
                document.getElementById('datSeries').style = 'display:none';
                $('#serieId').val("");
            });
        }
        else{
            document.getElementById('datSeries').innerHTML = "";
            document.getElementById('datSeries').style = 'display:none';
            $('#serieId').val("");
        }
    }
    function atencionU(){
        if(document.getElementById('atencion').value=="Si"){
            document.getElementById('mostrarRutaUbicacion').className="form-group row";
        }else{
            document.getElementById('mostrarRutaUbicacion').className="form-group row d-none";
        }
