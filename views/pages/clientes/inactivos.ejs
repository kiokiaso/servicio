<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Clientes Inactivos</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="/clientes">Clientes</a></li>
                        <li class="breadcrumb-item active">Clientes Inactivos</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
                <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearCliente">
                      Crear Cliente
                  </button> 
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="clientes">
                  <thead>
                    <tr>
                      <th>Código SAE</th>
                      <th>Razon social</th>
                      <th>Tipo de cliente</th>
                      <th>RFC</th>
                      <th>Email</th>
                      <th>Teléfono</th>
                      <th>Dirección</th>
                      
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% clientes.forEach(c=>{ %>
                        <tr class="fila-articulo" data-id="<%=c.id%>">
                            <td><%=c.codigo%></td>
                            <td><a href="/clientes/<%=c.id%>" class="enlace"><%=c.razonsocial%></a></td>
                            <td><%
                                if(c.esPolizaForanea){ %>
                                    <span class="badge badge-danger">Póliza entre exi</span> <%=c.oficina.nombre%>
                                <% }else{
                                    if(c.tipo=="ARRENDAMIENTO"){%>
                                        <span class="badge badge-primary">ARRENDAMIENTO</span>
                                    <%}if(c.tipo=="POLIZA"){%>
                                        <span class="badge badge-success">Póliza de servicio</span>
                                    <%} if(c.tipo=="TYM"){%>
                                        <span class="badge badge-secondary">TYM</span>
                                    <%}%>  
                                <% }
                            %></td>
                            <td><%=c.rfc%></td>
                            <td><%=c.email%></td>
                            <td><%=c.telefono%></td>
                            <td><%=c.direccion%></td>
                            <td>
                                <% if(!c.esPolizaForanea){ %>
                                    <a href="/clientes/activar/<%=c.id%>" class="btn btn-success">activar</a>
                                <% }%>
                            </td>
                        </tr>                        
                    <% })%>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
            </div>
          <!-- /.card -->
    </section>
</div>


<%- partial('../../partials/scripts/comun')%>
