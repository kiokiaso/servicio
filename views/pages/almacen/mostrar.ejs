                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- MODAL EDITAR ARTICULO -->
<div class="modal fade" id="editarArticulo" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearArticuloLabel">Editar Articulo</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/almacen/articulos/actualizar" method="POST" id="formCrearArticulo">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsArticulo" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresArticulo"></div>
                    </div>
                    
                    <div class="form-group row">
                        <label for="codigo" class="col-sm-2 col-form-label">Código*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="codigo" name="codigo" value="<%=articulo.codigo%>"  required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="clavealterna" class="col-sm-2 col-form-label">Clave Alterna*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="clavealterna" name="clavealterna" value="<%=articulo.clavealterna%>"  required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcion" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcion" name="descripcion"  required> <%=articulo.descripcion%></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="marca" class="col-sm-2 col-form-label">Marca*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="marca" name="marca" value="<%=articulo.marca%>"  required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="modelo" class="col-sm-2 col-form-label">Modelo*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="modelo" name="modelo" value="<%=articulo.modelo%>"  required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="garantia" class="col-sm-2 col-form-label">Garantia(cantidad en meses)*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="garantia" name="garantia" value="<%=articulo.garantia%>"  required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="preciopublico" class="col-sm-2 col-form-label">Precio Público*</label>
                        <div class="col-sm-10">
                            <input type="number" step="0.01" class="form-control" id="preciopublico" name="preciopublico" value="<%=articulo.preciopublico%>" placeholder="0" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="stockMinimo" class="col-sm-2 col-form-label">Stock Mínimo*</label>
                        <div class="col-sm-10">
                            <input type="number" step="0.01" class="form-control" id="stockMinimo" name="stockMinimo" value="<%=articulo.stockMinimo%>" placeholder="0" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="rendimiento" class="col-sm-2 col-form-label">Rendimiento*</label>
                        <div class="col-sm-10">
                            <input type="number" step="0.01" class="form-control" id="rendimiento" name="rendimiento" value="<%=articulo.rendimiento%>" placeholder="0" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tamano" class="col-sm-2 col-form-label">Tamaño*</label>
                        <div class="col-sm-10">
                            <select name="tamano" id="tamano" class="form-control">
                                <option value="A3" <%=articulo.tamano=='A3'?'selected':''%>>A3</option>
                                <option value="A4" <%=articulo.tamano=='A4'?'selected':''%>>A4</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="tipocolor" class="col-sm-2 col-form-label">Color o Monocromo*</label>
                        <div class="col-sm-10">
                            <select name="tipocolor" id="tipocolor" class="form-control">
                                <option value="Color" <%=articulo.tipocolor=='Color'?'selected':''%>>Color</option>
                                <option value="Monocromo" <%=articulo.tipocolor=='Monocromo'?'selected':''%>>Monocromo</option>
                            </select>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Editar</button>
                <input type="text" value="<%=articulo.id%>" class="form-control d-none" name="id" id="id">
                </form>
            </div>
        </div>
    </div>
</div>
<!-- VER SERIES -->
<div class="modal fade" id="verSeries" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="verSeriesLabel">Series</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="contenedorSeries">
                
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
