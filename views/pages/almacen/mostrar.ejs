                        <label for="costoAplicado" class="col-sm-2 col-form-label">Costo del movimiento*</label>
                        <div class="col-sm-10">
                            <input type="number" step="0.01" class="form-control" id="costoAplicado" name="costoAplicado" value="<%=articulo.costopromedio%>" placeholder="0" required>
