<script>
    $(document).ready(function () {
        var table = $('#avisosRemotos').DataTable({
            
            columnDefs: [
                {
                    searchable: false,
                    orderable: false,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
    });

    document.getElementById('checkAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('.check-item');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
    function cambiarAlmacenes(){
        let origen = document.getElementById("origen").value;
        let destino = document.getElementById("destino").value;
        const formulario = document.getElementById('formAlmacenes');
        if(origen!=0&&destino!=0){
            if(origen!=destino){
                formulario.submit();
            }
            else{
                $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'ERROR',
                    subtitle: 'Error',
                    body: 'Los almacenes deben ser diferentes'
                });
            }
        }
    }
    function atenderAvisos() {
        
        let datos = [];
        $('.check-item:checked').each(function() {
            let fila = $(this).closest('tr');
            datos.push(fila.data('id') );
        });

        if (datos.length === 0) return $(document).Toasts('create', {
                    class: 'bg-info',
                    title: 'ERROR',
                    subtitle: 'Aviso',
                    body: 'Selecciona por lo menos un aviso'
                });
        const idsCadeana = datos.join(',');
        window.location.href=`/avisos/remotos/iniciar-atencion?ids=${idsCadeana}`;
    }
    function obtenerDato(id){
    $.get(
        '/maestros/autos/obtener',
        {id:id},
        function (respuesta) {
            $('#editarAuto').modal('show');
            document.getElementById('placaEditar').value=respuesta.data.placa;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
            document.getElementById('kilometrajeEditar').value=respuesta.data.kilometraje;
            document.getElementById('idAuto').value=respuesta.data.id;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el puesto";
        document.getElementById('mostrarErroresAutoEditar').innerHTML=descErrores;
        $('#errorsAutoEditar').show();
        return false;
    });
  }
</script>