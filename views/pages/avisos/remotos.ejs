<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Atención avisos remotos</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Avisos</a></li>
                        <li class="breadcrumb-item active">Remotos</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
                <div class="col-12 float-left">
                    <div class="col-md-4 pt-4 float-left">
                        <button class="btn btn-success" onclick="atenderAvisos()">Iniciar Atención</button>
                    </div>
                </div>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="avisosRemotos">
                  <thead>
                    <tr>
                        <th>
                            <input type="checkbox" id="checkAll">
                        </th>
                        <th>ID</th>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Marca</th>
                        <th>stock Origen</th>
                        <th>stock Destino</th>
                        <th>Costo Promedio</th>
                        <th>Cantidad a Enviar</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% avisos.forEach(a=>{ %>
                        <tr class="fila-aviso" data-id="<%=a.id%>">
                            <td>
                                <input type="checkbox" class="check-item" value="<%=a.id%>">
                            </td>
                            <td><%=a.id%></td>
                            <td><%=a.id%></td>
                            <td><%=a.cliente.razonsocial%></td>
                            <td><%=a.ubicacion.nombre%></td>
                            <td  class="stock-max"><%=a.id%></td>
                            <td><%=a.id%></td>
                            <td></td>
                            <td><input type="number" class="form-control input-cant" min="1" max="<%=a.id%>"></td>
                        </tr>                        
                    <% })%>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
            </div>
          <!-- /.card -->
    </section>
</div>

<%- partial('../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>
