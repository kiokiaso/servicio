                                <tr class="fila-articulo" data-id="${s.id}">
                                    <td><input type="checkbox"  class="check-item"></td>
                                    <td>${s.numeroserie}</td>
                                    <td>${s.descripcion}</td>
                                    <td>${s.marca}</td>
