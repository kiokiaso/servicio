            <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-info small"><i class="fas fa-stream mr-2"></i>Intervenciones</h6>
        <span class="badge badge-info badge-pill"><%= intervenciones ? intervenciones.length : 0 %></span>
    </div>
    <div class="card-body p-2">
        <div class="timeline-container-scroll" style="max-height: 450px; overflow-y: auto;">
            <div class="timeline-compact">
                <% if(intervenciones && intervenciones.length > 0){ 
                    // Función interna para convertir minutos a HH:mm
                    const toHHMM = (totalMinutos) => {
                        if (!totalMinutos || isNaN(totalMinutos)) return "00:00";
                        const hrs = Math.floor(totalMinutos / 60);
                        const min = totalMinutos % 60;
                        return `${hrs.toString().padStart(2, '0')}:${min.toString().padStart(2, '0')}`;
                    };

                    intervenciones.forEach(i => { %>
                    
                    <div class="timeline-item-compact">
                        <div class="card border shadow-none mb-2 bg-light">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-xs font-weight-bold text-info">#<%= i.id %> - <%= i.tipoAviso ? i.tipoAviso.nombre : 'S/T' %></span>
                                    <% if(aviso.estado == 'pendiente'){ %>
                                        <a href="/avisos/intervencion/editar/<%= i.id %>" class="btn btn-xs p-0 text-info font-weight-bold" style="font-size: 0.65rem;">
                                            <i class="fas fa-edit mr-1"></i>EDITAR
                                        </a>
                                    <% } %>
                                    <a href="/avisos/descargar-pdf/<%= i.id %>" class="btn btn-xs p-0 text-success font-weight-bold" style="font-size: 0.65rem;">
                                            <i class="fas fa-edit mr-1"></i>Crear PDF
                                        </a>
                                </div>

                                <div class="row no-gutters mb-2 align-items-center">
                                    <div class="col-8">
                                        <p class="text-xs mb-0 text-dark">
                                            <i class="far fa-calendar-alt mr-1 text-muted"></i>
                                            <%= new Date(i.createdAt).toLocaleDateString('es-MX') %> 
                                            <span class="text-muted ml-1"><%= new Date(i.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                        </p>
                                        <p class="text-xs mb-0">
                                            <i class="fas fa-user-cog mr-1 text-muted"></i><%= i.atendidoPor ? i.atendidoPor.nombre : 'S/U' %>
                                        </p>
                                    </div>
                                    <div class="col-4 text-right">
                                        <% if(i.firma) { %>
                                            <img src="<%= i.firma %>" class="img-firma-mini rounded bg-white shadow-sm border" alt="Firma" style="max-height: 30px;">
                                        <% } %>
                                    </div>
                                </div>

                                <div class="bg-white border rounded p-2">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="atencion-range">
                                            <i class="far fa-clock"></i>
                                            <%= i.fechaInicio ? new Date(Number(i.fechaInicio)).toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }) : '--:--' %>
                                            <i class="fas fa-arrow-right"></i>
                                            <%= i.fechaCierre ? new Date(Number(i.fechaCierre)).toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit' }) : '--:--' %>
                                        </div>
                                        <span class="text-xs font-weight-bold text-muted" title="Contacto">
                                            <i class="fas fa-id-badge mr-1"></i><%= i.contacto ? i.contacto.nombre : 'Ausente' %>
                                        </span>
                                    </div>

                                    <div class="d-flex justify-content-around">
                                        <div class="metric-badge">
                                            <span class="metric-label">Respuesta</span>
                                            <span class="metric-value text-primary"><%= toHHMM(i.tiemporespuesta) %></span>
                                        </div>
                                        <div class="metric-badge">
                                            <span class="metric-label">Solución</span>
                                            <span class="metric-value text-success"><%= toHHMM(i.tiemposolucion) %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                <% })} else { %>
                    <div class="text-center py-3">
                        <small class="text-muted italic">No hay intervenciones registradas.</small>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
