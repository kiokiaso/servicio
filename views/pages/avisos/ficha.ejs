<style>
    body { background-color: #f8f9fa; }
    .card { border-radius: 12px; }
    .table thead th { border-top: none; }
    .shadow-sm { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important; }
   /* Contenedor con desplazamiento y altura máxima */
    .timeline-container-scroll {
        max-height: 400px; /* Ajusta este valor según prefieras */
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 5px;
    }

    /* Estilización de la barra de scroll para que sea sutil */
    .timeline-container-scroll::-webkit-scrollbar {
        width: 4px;
    }
    .timeline-container-scroll::-webkit-scrollbar-thumb {
        background: #17a2b8;
        border-radius: 10px;
    }

    /* Timeline ultra compacto */
    .timeline-compact {
        position: relative;
        padding-left: 1rem;
        border-left: 2px solid #e9ecef;
        margin-left: 10px;
    }

    .timeline-item-compact {
        position: relative;
        margin-bottom: 0.5rem;
    }

    .timeline-item-compact::before {
        content: "";
        position: absolute;
        left: calc(-1rem - 6px);
        top: 10px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #17a2b8;
        border: 2px solid #fff;
    }

    /* Miniatura de firma */
    .img-firma-mini {
        max-height: 35px;
        max-width: 80px;
        cursor: pointer;
        transition: transform 0.2s;
        border: 1px solid #ddd;
    }
    
    .img-firma-mini:hover {
        transform: scale(1.5);
        z-index: 10;
        position: relative;
    }

    .text-xs { font-size: 0.75rem !important; }
    /* Contenedor de métricas */
    .metric-badge {
        background-color: #ffffff;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        padding: 2px 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 65px;
    }
    
    .metric-label {
        font-size: 0.6rem;
        text-transform: uppercase;
        color: #6c757d;
        font-weight: bold;
        line-height: 1;
        margin-bottom: 2px;
    }

    .metric-value {
        font-size: 0.75rem;
        font-weight: bold;
        color: #343a40;
    }

    /* Rango de atención */
    .atencion-range {
        background: #e9ecef;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
        color: #495057;
        display: inline-flex;
        align-items: center;
    }

    .atencion-range i {
        font-size: 0.6rem;
        margin: 0 5px;
        color: #17a2b8;
    }
</style>

