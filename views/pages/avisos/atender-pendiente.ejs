<!-- SweetAlert2 -->
<script src="/plugins/sweetalert2/sweetalert2.min.js"></script>

<script>
function procesarEnvio() {
    const $btn = $('#btnGuardarAtencion');
    const tipoAviso = <%= aviso.tipoAviso %>;
    const intervencion = <%= intervencionId %>;
    let datosPlantilla
    // 1. Validar Contadores (Solo si tipoAviso != 3 y 4)
    if (tipoAviso != 3 && tipoAviso != 4) {
        // Asumiendo que tus inputs tienen name="monocromoEntrada", etc.
        const monoE = parseInt($('input[name="monocromoEntrada"]').val()) || 0;
        const monoS = parseInt($('input[name="monocromoSalida"]').val()) || 0;
        const colE = parseInt($('input[name="colorEntrada"]').val()) || 0;
        const colS = parseInt($('input[name="colorSalida"]').val()) || 0;
        const escE = parseInt($('input[name="escanerEntrada"]').val()) || 0;
        const escS = parseInt($('input[name="escanerSalida"]').val()) || 0;

        if (monoE > monoS || colE > colS || escE > escS) {
            alert('¡Error! Los contadores de entrada no pueden ser mayores a los de salida.');
            return;
        }
        if(tipoAviso==1){
            
            datosPlantilla = {
                nombre: "<%= plantilla?plantilla.nombre:0 %>", // Tomado de la variable EJS
                campos: []
            };

            // Recorremos los campos que definimos en el HTML anterior
            // Usamos la variable 'plantilla' de EJS para saber qué IDs buscar
            <% if(plantilla){plantilla.campos.forEach(function(campo) { %>
                if (<%= campo.activo %>) {
                    let valor = "";
                    <% if (campo.tipo === 'opciones') { %>
                        // Obtener valor de radio buttons
                        valor = $("input[name='campo_<%= campo.id %>']:checked").val() || "";
                    <% } else { %>
                        // Obtener valor de input number
                        valor = $("input[name='campo_<%= campo.id %>']").val();
                    <% } %>

                    datosPlantilla.campos.push({
                        id: <%= campo.id %>,
                        nombre: "<%= campo.nombre %>",
                        tipo: "<%= campo.tipo %>",
                        valor: valor
                    });
                }
            <% })}; %>
        }
    }
    // 1. Validar Contadores (Solo si tipoAviso != 3 y 4)
    /*if (tipoAviso != 3 && tipoAviso != 4) {
        // Asumiendo que tus inputs tienen name="monocromoEntrada", etc.
        const monoE = parseInt($('input[name="monocromoEntrada"]').val()) || 0;
        const monoS = parseInt($('input[name="monocromoSalida"]').val()) || 0;
        const colE = parseInt($('input[name="colorEntrada"]').val()) || 0;
        const colS = parseInt($('input[name="colorSalida"]').val()) || 0;
        const escE = parseInt($('input[name="escanerEntrada"]').val()) || 0;
        const escS = parseInt($('input[name="escanerSalida"]').val()) || 0;

        if (monoE > monoS || colE > colS || escE > escS) {
            alert('¡Error! Los contadores de entrada no pueden ser mayores a los de salida.');
            return;
        }
    }*/

    // 2. Recopilar Materiales de la tabla
    let materiales = [];
    if(tipoAviso!=3){
        $('#tablaMat tbody tr').each(function() {
            const row = $(this);
            materiales.push({
                id: row.attr('id').replace('mat-', ''),
                cantidad: parseInt(row.find('input').val()),
                costopromedio: row.data('costopromedio'), // Asegúrate de guardar esto en agregarMat
                preciopublico: row.data('preciopublico')
            });
        });
    }

    // 3. Estructurar Objeto Final
    const dataFinal = {
        avisoId: <%= aviso.id %>,
        equipoId: <%= equipo.id %>,
        avisoEquipoId: <%= avisoEquipo.id %>,
        idEquipoInt:<%=equipoIntervencion.id%>,
        intervencion,
        horaInicio: $('#horaInicioAtencion').val(),
        estadoEquipo: $('input[name="estado"]:checked').val(),
        observaciones: $('textarea[name="observaciones"]').val(),
        contadores: $('#formAtencion').serializeArray(),
        materiales: materiales // Puede ir vacío []
    };

    // 4. Envío por POST
    $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Enviando...');

        $.post('/avisos/equipos/atender/guardar-pendiente', dataFinal, function(res) {
            swal.fire({
                title: "¡Equipo Atendido!",
                text: res.message,
                icon: "success",
                timer: 2000,
                buttons: false // Oculta el botón para que sea automático
            }).then(() => {
                window.location.href = `/avisos/${res.avisoId}`;
            });
        
    }).fail(function(err) {
        alert('Error al guardar');
        $btn.prop('disabled', false).text('Terminar');
    });
}


function buscarMateriales(input) {
    let q = input.value;
    let res = $('#resMat');

    // Solo buscar a partir del tercer carácter
    if (q.length < 3) { 
        res.hide(); 
        return; 
    }

    // Petición GET tradicional
    $.get('/avisos/articulos/buscar', { q: q }, function(data) {
        if (data && data.length > 0) {
            res.empty().show();
            
            // Limitamos a 5 coincidencias como pediste
            data.slice(0, 5).forEach(m => {
                res.append(`
                    <button type="button" class="list-group-item list-group-item-action py-2" 
                        onclick="agregarMat('${m.id}', '${m.nombre}', ${m.existencia},${m.costopromedio},${m.preciopublico})">
                        <div class="d-flex justify-content-between small">
                            <span class="font-weight-bold text-uppercase">${m.nombre}</span>
                            <span class="badge badge-info">Stock: ${m.existencia}</span>
                        </div>
                    </button>`);
            });
        } else {
            res.hide();
        }
    }).fail(function() {
        console.error("Error al buscar materiales");
        res.hide();
    });
}
function actualizarCantidadContador(input){
        $.post('/avisos/intervencion/contador/actualizar', {id:input.getAttribute('data-id'),valor:input.value}, function(res) {
            if(res.ok==true){
                swal.fire("¡Éxito!", "Cantidad actualizada de forma correcta", "success");
            }else{
                swal.fire("¡Error!", res.msj, "error");
            }
            
        }).fail(() => swal.fire("Error", "No se ha podido actualizar la cantidad", "error"));
    }

function agregarMat(id, nombre, stock,costopromedio,preciopublico) {
    if ($(`#mat-${id}`).length) return; // No duplicar

    $('#tablaMat tbody').append(`
        <tr id="mat-${id}" data-costopromedio=${costopromedio} data-preciopublico=${preciopublico}>
            <td class="small align-middle">${nombre}</td>
            <td>
                <input type="number" class="form-control form-control-sm" 
                    min="1" max="${stock}" value="1" 
                    onchange="checkStock(this, ${stock})">
            </td>
            <td class="align-middle">
                <a href="javascript:void(0)" class="text-danger" onclick="$('#mat-${id}').remove()">
                    <i class="fas fa-trash"></i>
                </a>
            </td>
        </tr>
    `);
    $('#resMat').hide();
    $('#busquedaMat').val('');
}

function checkStock(el, max) {
    if (parseInt(el.value) > max) {
        alert('Existencia insuficiente. Máximo: ' + max);
        el.value = max;
    }
}

</script>