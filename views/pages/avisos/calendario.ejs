<script>
    $(document).ready(function() {
        const urlParams = new URLSearchParams(window.location.search);
        const avisoId = urlParams.get('editAviso');
        const target = urlParams.get('redirect');

        if (avisoId) {
            // 1. Dispara tu función actual que abre el modal
            // Ajusta 'abrirModalEdicion' al nombre real de tu función
            $.get(
                '/avisos/obtener',
                { id:avisoId },
                function (res) {
                    if(res.resp==1){
                        $('#programacion').modal('show');
                        document.getElementById('idAviso').value=res.aviso.id
                        document.getElementById('txtFolioModal').innerHTML=res.aviso.folio
                        document.getElementById('txtClienteModal').innerHTML=res.aviso.cliente.razonsocial
                        document.getElementById('ingeniero').value=res.aviso.atendidoPor,
                        document.getElementById('redirect').value='Si'
                        const fecha = res.aviso.fechaAtencion;
                        const fechaFin = res.aviso.fechaFin;
                         document.getElementById('manualFechaInicio').value = formatearFecha(fecha);
                         document.getElementById('manualFechaFin').value = formatearFecha(fechaFin);
                        //document.getElementById('manualFechaInicio').value=res.aviso.fechaAtencion
                    }
                    
            }).fail(function (res) {
                
            });
            
        }
    });
    function formatearFecha(fecha){
        const dt = new Date(fecha);
        const formatted =
            dt.getFullYear() + "-" +
            String(dt.getMonth() + 1).padStart(2, '0') + "-" +
            String(dt.getDate()).padStart(2, '0') + "T" +
            String(dt.getHours()).padStart(2, '0') + ":" +
            String(dt.getMinutes()).padStart(2, '0');
        return formatted
    }
document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('calendar');
    const filtro = document.getElementById('filtroIngeniero');

    const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'timeGridWeek',
        locale: 'es',
        firstDay: 1, // Lunes
        height:'auto',
        contentHeight:400,
        aspectRatio:1.5,
        allDaySlot: true,
        slotMinTime: '08:00:00',
        slotMaxTime: '19:00:00',
        slotDuration:'00:15:00',
        slotLabelInterval:'01:00:00',
        expandRows:false,
        editable: true, // Habilitar Drag & Drop
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'timeGridWeek,timeGridDay,dayGridMonth'
        },
        
        // Carga de eventos inicial
        events: '/avisos/eventos-calendario',

        // RESTRICCIÓN: Solo avisos NO finalizados son movibles
        eventStartEditable: function(event) {
            return event.extendedProps.estado !== 'finalizado';
        },

        // AL ARRASTRAR Y SOLTAR
        eventDrop: async function(info) {
            const avisoId = info.event.id;
            const nuevaFecha = info.event.startStr;
            const ingenieroId = info.event.extendedProps.ingenieroId;

            const esAsignacionNueva = !info.event.allDay;

            // Bloquear interfaz mientras valida
            Swal.showLoading();

            try {
                const response = await fetch('/avisos/validar-y-mover', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: avisoId,
                        fechaAtencion: nuevaFecha,
                        atendidoPor: ingenieroId,
                        esAsignacionNueva:esAsignacionNueva
                    })
                });

                const res = await response.json();

                if (!response.ok) {
                    Swal.fire(res.titulo, res.message, 'warning');
                    info.revert(); // Regresa el evento a su lugar original
                } else {
                    // Actualizar la hora de fin recalculada por el servidor
                    info.event.setEnd(res.nuevaFechaFin);
                    info.event.setProp('backgroundColor', res.nuevoColor);
                    info.event.setProp('borderColor', res.nuevoColor);
                    
                    // Asegurar que no regrese a "All Day"
                    info.event.setProp('allDay', false);

                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 2000
                    });
                    Toast.fire({ icon: 'success', title: 'Programación actualizada' });
                }
            } catch (error) {
                Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
                info.revert();
            }
        },

        // AL DAR CLIC (Para edición manual)
        eventClick: function(info) {
            if (info.event.extendedProps.estado === 'finalizado') {
                Swal.fire('Aviso Finalizado', 'No se puede editar la programación de un aviso cerrado.', 'info');
                return;
            }
            console.log("Datos del evento",info.event.startStr)
            // Aquí puedes llamar a tu modal de edición si lo deseas
            $('#programacion').modal('show');
            document.getElementById('idAviso').value=info.event.id
            document.getElementById('txtFolioModal').innerHTML=info.event.extendedProps.folio
            document.getElementById('txtClienteModal').innerHTML=info.event.title
            document.getElementById('ingeniero').value=info.event.extendedProps.ingenieroId
            document.getElementById('manualFechaInicio').value = formatearFecha(info.event.startStr);
            document.getElementById('manualFechaFin').value = formatearFecha(info.event.endStr);
            //window.location.href = '/avisos/' + info.event.id;
        },

        // DISEÑO DEL EVENTO
        eventContent: function(arg) {
            let esFinalizado = arg.event.extendedProps.estado === 'finalizado';
            let esAllDay = arg.event.allDay; // Detectamos si está en la barra superior "Por asignar"
            //console.log("datos",arg)
    
            // Formateamos las horas solo si NO es allDay
            let htmlHoras = '';
            if (!esAllDay) {
                htmlHoras = `<div style="font-size: 0.65rem; opacity: 0.8;">
                                ${moment(arg.event.start).format('HH:mm')} - ${moment(arg.event.end).format('HH:mm')}
                            </div>`;
            }

            return {
                html: `
                <div class="p-1" style="line-height: 1.2; overflow: hidden; height: 100%;color:#FFF">
                    <div style="font-size: 0.75rem; font-weight: bold;">
                        ${esFinalizado ? '<i class="fas fa-lock small"></i>' : ''} 
                        #${arg.event.extendedProps.folio}
                    </div>
                    <div class="text-truncate" style="font-size: 0.7rem;">${arg.event.title}</div>
                    <div class="text-truncate" style="font-size: 0.7rem;">${arg.event.extendedProps.ingeniero}</div>
                    
                </div>`
            };
        }
    });

    calendar.render();

    // FILTRO DINÁMICO
    filtro.addEventListener('change', function() {
        const ingId = this.value;
        // Limpiamos y recargamos con el parámetro de ingeniero
        calendar.removeAllEventSources();
        calendar.addEventSource({
            url: '/avisos/eventos-calendario',
            extraParams: { ingenieroId: ingId }
        });
    });
});
async function agregarEquipoAviso() {
    const data = {
        idAviso: $('#idAviso').val(),
        ingeniero: $('#ingeniero').val(),
        manualFechaInicio: $('#manualFechaInicio').val(),
        manualFechaFin: $('#manualFechaFin').val()
    };

    // Bloquear botón y mostrar loading
    Swal.showLoading();

    try {
        const response = await fetch('/avisos/modificar-programacion-manual', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        const res = await response.json();

        if (!response.ok) {
            // Mostrar error en el div del modal
            $('#mostrarErroresEquipo').html(`<strong>Error:</strong> ${res.message}`);
            $('#errorsEquipo').fadeIn();
            Swal.close();
        } else {
            $('#programacion').modal('hide');
            
            Swal.fire({
                icon: 'success',
                title: '¡Actualizado!',
                text: res.message,
                timer: 1500,
                showConfirmButton: false
            }).then(() => {
                // Opción A: Recargar la página (Más seguro para sincronizar todo)
                if(document.getElementById('redirect').value=="No"){
                    location.reload();
                }else{
                    window.location.href = '/avisos/' + data.idAviso;
                }
                
            });
        }
    } catch (error) {
        Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
    }
}
// Referencias a los elementos
const inputInicio = document.getElementById('manualFechaInicio');
const inputFin = document.getElementById('manualFechaFin');

// 1. Al cambiar el INICIO
inputInicio.addEventListener('change', function() {
    // Validar Domingo
    const fecha = new Date(this.value);
    if (fecha.getUTCDay() === 0) {
        Swal.fire('Día no laboral', 'No se pueden programar avisos los domingos.', 'warning');
        this.value = '';
        return;
    }

    // El Fin no puede ser antes que el Inicio
    // Ajustamos el "min" del input de fin para que el navegador bloquee fechas anteriores
    inputFin.setAttribute('min', this.value);

    // Si el valor actual de fin es menor al nuevo inicio, lo igualamos o lo limpiamos
    if (inputFin.value && inputFin.value < this.value) {
        inputFin.value = this.value;
        Toast.fire({ icon: 'info', title: 'Se ajustó el fin al horario de inicio' });
    }
});

// 2. Al cambiar el FIN
inputFin.addEventListener('change', function() {
    // Validar Domingo
    const fecha = new Date(this.value);
    if (fecha.getUTCDay() === 0) {
        Swal.fire('Día no laboral', 'No se pueden programar avisos los domingos.', 'warning');
        this.value = '';
        return;
    }

    // Validar que no sea menor al inicio manualmente (por si el navegador no soporta 'min')
    if (inputInicio.value && this.value < inputInicio.value) {
        Swal.fire('Error de horario', 'La fecha de fin no puede ser anterior al inicio.', 'error');
        this.value = inputInicio.value;
    }
});
$('#programacion').on('show.bs.modal', function () {
    const ahora = new Date().toISOString().slice(0, 16);
    
    // Evitar programar en el pasado
    inputInicio.setAttribute('min', ahora);
    
    // Si ya hay un valor cargado en inicio, actualizar el min de fin
    if (inputInicio.value) {
        inputFin.setAttribute('min', inputInicio.value);
    } else {
        inputFin.setAttribute('min', ahora);
    }
});




</script>