<style>
    #datSeries {
        box-shadow: 2px 2px 8px 0 rgba(0,0,0,.2);
        height: auto;
        /*position: absolute;*/
        top: 45px;
        z-index: 9999;
        width: 206px;
        text-align: center;
        background-color: #e8e8e8;
    }
    #datSeries .suggest-element {
        background-color: #0067c6;
        border-top: 1px solid #d6d4d4;
        cursor: pointer;
        padding: 8px;
        width: 100%;
        float: left;
        color:#FFF;
        border-radius: 0px 0px 5px 5px;

    }
     #datClientes {
        box-shadow: 2px 2px 8px 0 rgba(0,0,0,.2);
        height: auto;
        /*position: absolute;*/
        top: 45px;
        z-index: 9999;
        width: 206px;
        text-align: center;
        background-color: #e8e8e8;
    }
    #datClientes .suggest-element {
        background-color: #0067c6;
        border-top: 1px solid #d6d4d4;
        cursor: pointer;
        padding: 8px;
        width: 100%;
        float: left;
        color:#FFF;
        border-radius: 0px 0px 5px 5px;

    }
</style>
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Crear avisos de tomas de lecturas</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item active">Asistencias</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-end flex-wrap">
                <form id="form-busqueda" class="form-inline mb-2 mb-md-0" action=" /lecturas/avisos" method="post">
                    <div class="form-group mr-2">
                        <label for="fechaInicio" class=" font-weight-bold d-block mb-1">Fecha Inicio </label>
                        <input type="date" class="form-control form-control-sm" id="fechaInicio" name="fechaInicio" value="<%=fechaInicio?fechaInicio:''%>">
                    </div>
                    
                    <div class="form-group mr-2">
                        <label for="fechaFin" class=" font-weight-bold d-block mb-1">Fecha Fin </label>
                        <input type="date" class="form-control form-control-sm" id="fechaFin" name="fechaFin" value="<%=fechaFin?fechaFin:''%>">
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm align-self-end mt-4 mt-md-0">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                </form>
                <div class="mb-0 ml-auto">
                    <button type="button" class="btn btn-success btn-sm px-3" onclick="crearAviso()">
                        <i class="fas fa-plus"></i> Crear Avisos
                    </button>
                </div>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="equipos">
                  <thead>
                    <tr>
                        <th class="text-center" style="width: 40px;">
                            <input type="checkbox" id="checkAll">
                        </th>
                        <th>Nombre</th>
                        <th>Fecha prevista</th>
                        <th>Agrupar equipos</th>
                        <th>Cliente</th>
                        <th>Ubicación</th>
                        <th>Equipos</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% lecturas.forEach(c=>{ %>
                        <tr class="fila-articulo" data-id="<%=c.id%>">
                            <td class="text-center">
                                <input type="checkbox" class="checkItem" value="<%=c.id%>">
                            </td>
                            <td><a href="/equipos/<%=c.id%>" class="enlace"><%=c.lectura.nombre%></a></td>
                            <td><%= new Date(c.fecha).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' })  %></td>
                            <td><%=c.lectura.agruparequipos==true?'Si':'No'%></td>
                            <td><%=c.cliente.razonsocial%></td>
                            <td><%=c.ubicacion.nombre %> <br>
                            <%
                                if(c.ubicacion&&c.ubicacion.oficinaAtencion===oficinaElegida.id){ %>
                                    <span class="badge badge-danger">Póliza entre exi <%=c.oficina.nombre%></span> 
                                <% }else{
                                    
                                    if(c.tipoequipo=="ARRENDAMIENTO"){%>
                                        <%=c.cliente.razonsocial%> <span class="badge badge-primary">ARRENDAMIENTO</span>
                                    <%}if(c.tipoequipo=="POLIZA"){%>
                                        <%=c.cliente.razonsocial%> <span class="badge badge-success">Póliza de servicio</span>
                                    <%} if(c.tipoequipo=="TYM"){%>
                                        <%=c.cliente.razonsocial%> <span class="badge badge-secondary">TYM</span>
                                    <%}%>  
                                <% }
                            %></td>
                            <td> <%=c.equipos.length%></td>
                        </tr>                        
                    <% })%>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
            </div>
          <!-- /.card -->
    </section>
</div>

<%- partial('../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>
<!-- SweetAlert2 -->
<script src="/plugins/sweetalert2/sweetalert2.min.js"></script>
<script>
    $(document).ready(function () {
        var table = $('#equipos').DataTable({
            stateSave: true,
            
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            columnDefs: [
                { orderable: false, targets: 0 }
            ],
            order: [[1, 'asc']],
        });
    });
    document.getElementById('checkAll').addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('.checkItem');
        checkboxes.forEach(cb => cb.checked = this.checked);
    });
    function crearAviso() {
        let datos = [];
        let totalAvisos=0;
        $('.checkItem:checked').each(function() {
            let fila = $(this).closest('tr');
            let celdas = fila.find('td');
            let agruparEquipos = $(celdas[3]).text().trim();
            let cantidadEquipos = parseInt($(celdas[6]).text().trim()) || 0;
            if (agruparEquipos.toLowerCase() === 'si') {
                totalAvisos += 1;
            } else {
                totalAvisos += cantidadEquipos;
            }
            /*let cant = parseInt(fila.find('.input-cant').val());
            let max = parseInt(fila.find('.stock-max').text());

            if (cant > 0 && cant <= max) {*/
                datos.push({ id: fila.data('id')});
            //}
        });

        if (datos.length === 0) return $(document).Toasts('create', {
                    class: 'bg-info',
                    title: 'ERROR',
                    subtitle: 'Aviso',
                    body: 'Debes seleccionar por lo menos una toma de lectura'
                });
        Swal.fire({
            title: '¿Deseas generar los avisos?',
            text: `Se van a generar ${totalAvisos} avisos en total`,
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6', // Azul profesional
            cancelButtonColor: '#6c757d', // Gris neutro
            confirmButtonText: '<i class="fas fa-check"></i> Acepto',
            cancelButtonText: 'Cancelar',
            reverseButtons: true,
            allowOutsideClick: false 
        }).then((result) => {
            if (result.isConfirmed) {
                // Aquí ejecutas tu lógica de AJAX
                Swal.fire({
                    title: 'Generando avisos...',
                    html: 'Por favor espere un momento.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
                let desc=result.value
                $.post(
                    '/lecturas/avisos/crear',
                    {datos},
                    function (res) {
                        Swal.fire({
                            title: '¡Operación Exitosa!',
                            text: `Se han generado ${res.cantidad} avisos correctamente.`,
                            icon: 'success',
                            confirmButtonText: 'Entendido'
                        }).then(() => {
                            location.reload(); // Recargamos para ver los cambios en la tabla
                        });
                        
                    }).fail(function (res) {
                        Swal.fire('Error', 'No se pudieron generar los avisos. Intente de nuevo.', 'error');
                    });
                //alert(`Has elegido que si: ${desc}`)
            }
        });
        /*$.post('/lecturas/avisos/crear', { datos }, function(res) {
            $(document).Toasts('create', {
                    class: 'bg-success',
                    title: 'Éxito',
                    subtitle: 'Aviso',
                    body: 'Transferencia completada'
                });
            setTimeout(function(){
                location.reload();
            },1000)
             
        }).fail(err => Swal.fire('Error', err.responseText, 'error'));*/
    }
  
</script>