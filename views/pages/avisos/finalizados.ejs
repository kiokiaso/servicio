<style>
    #datSeries {
        box-shadow: 2px 2px 8px 0 rgba(0,0,0,.2);
        height: auto;
        /*position: absolute;*/
        top: 45px;
        z-index: 9999;
        width: 206px;
        text-align: center;
        background-color: #e8e8e8;
    }
    #datSeries .suggest-element {
        background-color: #0067c6;
        border-top: 1px solid #d6d4d4;
        cursor: pointer;
        padding: 8px;
        width: 100%;
        float: left;
        color:#FFF;
        border-radius: 0px 0px 5px 5px;

    }
     #datClientes {
        box-shadow: 2px 2px 8px 0 rgba(0,0,0,.2);
        height: auto;
        /*position: absolute;*/
        top: 45px;
        z-index: 9999;
        width: 206px;
        text-align: center;
        background-color: #e8e8e8;
    }
    #datClientes .suggest-element {
        background-color: #0067c6;
        border-top: 1px solid #d6d4d4;
        cursor: pointer;
        padding: 8px;
        width: 100%;
        float: left;
        color:#FFF;
        border-radius: 0px 0px 5px 5px;

    }
</style>
<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Avisos finalizados</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item active">Finalizados</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
                <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearAviso">
                      Crear Aviso
                  </button> 
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="equipos">
                  <thead>
                    <tr>
                        <th>Id</th>
                        <th>Tipo</th>
                        <th>Cliente</th>
                        <th>Fecha de creación</th>
                        <th>Fecha de cierre</th>
                        <th>Prioridad</th>
                        <th>Equipo</th>
                        <th>Usuario asignado</th>
                        <th>Problema</th>
                        <th>Tiempon de respuesta</th>
                        <th>tiempo de solución</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% 
                    function calcularHHMM(min){
                                        let horas = Math.floor(min / 60);
                                        let minutos = min % 60;
                                        
                                        // Formateamos para que siempre tengan dos dígitos (ej. 01:05)
                                        let hh = horas.toString().padStart(2, '0');
                                        let mm = minutos.toString().padStart(2, '0');
                                        return hh+":"+mm
                                    }
                    avisos.forEach(c=>{ %>
                        <tr class="fila-aviso" data-id="<%=c.id%>">
                            <td><a href="/avisos/<%=c.id%>" class="enlace"><%=c.id%></a></td>
                            <td>
                                <%if(c.tipoAviso.id==3){%>
                                <i class="bi bi-speedometer" data-toggle="tooltip" data-placement="top" title="Toma de lectura"></i>
                                <% }else if(c.tipoAviso.id==1){ %>
                                <i class="far fa-clock" data-toggle="tooltip" data-placement="top" title="Mantenimiento Preventivo"></i>
                                <% }else if(c.tipoAviso.id==2){ %>
                                <i class="fas fa-tools" data-toggle="tooltip" data-placement="top" title="Avería"></i>
                                <% }else{ %>
                                <i class="bi bi-droplet-fill" data-toggle="tooltip" data-placement="top" title="Entrega de tóner"></i> 
                                <% } %>
                            </td>
                            <td><strong><%=c.cliente.razonsocial%></strong><br>(<%=c.ubicacion.nombre%>)<br>
                                <% if(c.ubicacion&&c.ubicacion.oficinaAtencion===oficinaElegida.id){ %>
                                    <span class="badge badge-danger">Póliza entre exi <%=c.oficina.nombre%></span> 
                                <% }  %>
                            </td>
                            <td><%= new Date(Number(c.createdAt)).toLocaleString('es-ES', {  day: '2-digit', month: '2-digit',  year: 'numeric', hour: '2-digit',  minute: '2-digit' }) %></td>
                            <td><%= new Date(c.fechaCierre).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric',hour: '2-digit', minute: '2-digit'  }) %>
                                <% let objetivo=c.trEstimado
                                if(c.ubicacion&&c.ubicacion.oficinaAtencion===oficinaElegida.id){ 
                                    objetivo=c.trPoliza
                                }  
                                if(c.tiemporespuesta>objetivo) { %>
                                    <span class="badge badge-danger">
                                        <i class="fas fa-history"></i> VENCIDO: <%= calcularHHMM(c.tiemporespuesta)  %> 
                                    </span>
                                    <div class="small text-danger">Límite: <%= calcularHHMM(objetivo) %> </div>
                                <% } else { %>
                                    <span class="badge badge-success">
                                        <i class="fas fa-check"></i> <%= calcularHHMM(c.tiemporespuesta) %> 
                                    </span>
                                    <div class="small text-muted">Límite: <%= calcularHHMM(objetivo) %> </div>
                                <% } %>
                            </td>
                            <td><%=c.prioridad.nombre%></td>
                            <td> <% c.equiposInvolucrados.forEach(e=>{ %>
                                <strong><%=e.equipo.serie%></strong>-(<span><%=e.equipo.tipoProblema%></span>)<br>
                                <% }) %>
                            </td>
                            <td>
                                <%=c.atendidoPor.nombre%>
                            </td>
                            <td><%=c.observaciones%></td>
                            <td><% 
                                    // Suponiendo que minutosAtencion es el campo con el total de minutos
                                    let h = Math.floor(c.tiemporespuesta / 60);
                                    let m = c.tiemporespuesta % 60;
                                    
                                    // Formatear para que siempre tenga dos dígitos (00:00)
                                    let tiempoFormateado = (h < 10 ? '0' + h : h) + ':' + (m < 10 ? '0' + m : m);
                                %>

                                <p> <%= tiempoFormateado %></p>
                            </td>
                            <td><% 
                                    // Suponiendo que minutosAtencion es el campo con el total de minutos
                                    let hs = Math.floor(c.tiemposolucion / 60);
                                    let ms = c.tiemposolucion % 60;
                                    
                                    // Formatear para que siempre tenga dos dígitos (00:00)
                                    let tiempoFormateadoS = (hs < 10 ? '0' + hs : hs) + ':' + (ms < 10 ? '0' + ms : ms);
                                %>

                                <p> <%= tiempoFormateadoS %></p>
                            </td>
                        </tr>                        
                    <% })%>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
            </div>
          <!-- /.card -->
    </section>
</div>

<!-- MODAL AGREGAR EQUIPO -->
<div class="modal fade" id="crearLectura" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="agregarEquipoLabel">Crear Lectura</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" >
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsEquipo"
                        style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                        <div id="mostrarErroresEquipo"></div>
                    </div>

                    <div class="form-group row">    
                        <label for="clienteNombre" class="col-sm-2 col-form-label">Cliente*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="clienteNombre" name="clienteNombre" required onkeyup="buscarCliente()">
                             <div id="datClientes" style="display: none;">

                            </div>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="ubicacion" class="col-sm-2 col-form-label">Ubicación*</label>
                        <div class="col-sm-10">
                            <select name="ubicacion" id="ubicacion" class="form-control" onchange="buscarEquipos()">
                                
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">    
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" required>
                        </div>
                    </div>
                    <div class="form-group row">    
                        <label for="inicio" class="col-sm-2 col-form-label">Fecha de inicio*</label>
                        <div class="col-sm-10">
                            <input type="date" class="form-control" id="inicio" name="inicio" required>
                        </div>
                    </div>
                    <div class="form-group row">    
                        <label for="fin" class="col-sm-2 col-form-label">Fecha de fin*</label>
                        <div class="col-sm-10">
                            <input type="date" class="form-control" id="fin" name="fin" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="agrupar" class="col-sm-2 col-form-label">Agrupar elementos*</label>
                        <div class="col-sm-10">
                            <select name="agrupar" id="agrupar" class="form-control">
                                <option value="true">Si</option>
                                <option value="false">No</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="observaciones" class="col-sm-2 col-form-label">Observaciones*</label>
                        <div class="col-sm-10">
                            <textarea name="observaciones" id="observaciones" rows="3" class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="table table-responsive">
                        <table id="tablaEquipos" class="w-100">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Serie</th>
                                    <th>Descripción</th>
                                    <th>Marca</th>
                                    <th>Modelo</th>
                                </tr>
                            </thead>
                            <tbody>

                            </tbody>
                        </table>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="guardarDatos()">Crear</button>
                <input type="text" class="d-none" name="cliente" id="cliente" onchange="buscarUbicaciones()">
                <input type="text" class="d-none" name="oficina" id="oficina" value="<%=oficinaElegida.id%>">
                </form>
            </div>
        </div>
    </div>
</div>
