<script>
    $(function () {
        $('[data-toggle="tooltip"]').tooltip();
    });
    $(document).ready(function () {
        var table = $('#equipos').DataTable({
            stateSave: true,
            
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'desc']],
        });
    });

    function guardarDatos(){
        let datos = [];
        let oficina=document.getElementById('oficina').value;
        let ubicacion=document.getElementById('ubicacion').value;
        let cliente=document.getElementById('cliente').value;
        let nombre=document.getElementById('nombre').value;
        let inicio=document.getElementById('inicio').value;
        let agrupar=document.getElementById('agrupar').value;
        let fin=document.getElementById('fin').value;
        /*if(agrupar=="True"){
            agrupar=true
        }else{
            agrupar=false;
        }*/
        let observaciones=document.getElementById('observaciones').value;
        $('.check-item:checked').each(function() {
            let fila = $(this).closest('tr');
            datos.push({ id: fila.data('id') });
        });
        if(datos.length==0){
            return $(document).Toasts('create', {
                class: 'bg-danger',
                title: 'Error',
                body: `Debes seleccionar por lo menos un equipo`,
            })
        }
        $.post(
            '/lecturas/crear',
            {equipos:datos,oficina,ubicacion,cliente,nombre,inicio,agruparequipos:agrupar,observaciones,fin},
            function (res) {
                if(res.resp==1){
                    window.location.href = `/lecturas/${res.lectura.id}`;
                }
            }).fail(function (res) {
               $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    body: `Se ha producido un error al momento de crear la lectura`,
                })
            });
    };

    function buscarEquipos(){
        var numero = document.getElementById("ubicacion").value;
        var cliente = document.getElementById("cliente").value;
        var oficina = document.getElementById("oficina").value;
       
            $.get(
                '/lecturas/equipos/buscar',
                { ubicacion: numero,oficina,cliente },
                function (res) {
                    const tbody = document.querySelector('#tablaEquipos tbody');
                    let contenido=``;
                    res.equipos.forEach(s => {
                        contenido = contenido + `
                            <tr class="fila-articulo" data-id="${s.id}">
                                <td><input type="checkbox"  class="check-item"></td>
                                <td>${s.numeroserie}</td>
                                <td>${s.descripcion}</td>
                                <td>${s.marca}</td>
                                <td>${s.modelo}</td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML=contenido;
            }).fail(function (res) {
                document.getElementById('datSeries').innerHTML = "";
                document.getElementById('datSeries').style = 'display:none';
                $('#serieId').val("");
            });
        
    }
    function buscarCliente(){
        var numero = document.getElementById("clienteNombre").value;
        var contenido="<div><strong>Clic al cliente para elegirlo</strong></div>";
        if(numero.length>2){
            $.get(
                '/equipos/clientes/buscar',
                { cliente: numero},
                function (res) {
                    res.clientes.forEach(s => {
                        contenido = contenido + `<div style="cursor:pointer"><a class="suggest-element" data="${s.id}" nombre="${s.razonsocial}"  id="${s.id}" oficina="${s.oficina.id}">${s.razonsocial}</a></div>`;

                    });
                    $('#datClientes').fadeIn(1000).html(contenido);
                    $('.suggest-element').on('click', function () {
                                //Obtenemos la id unica de la sugerencia pulsada
                        var id = $(this).attr('id');
                        var nombre = $(this).attr('nombre');
                        var oficina = $(this).attr('oficina');
                        $('#clienteNombre').val($('#' + id).attr('data'));
                                    //Hacemos desaparecer el resto de sugerencias
                        document.getElementById('datClientes').innerHTML = "";
                        document.getElementById('datClientes').style = 'display:none';
                                    //alert('Has seleccionado el '+id+' '+$('#'+id).attr('data'));
                        $('#clienteNombre').val(nombre);
                        $('#cliente').val(id);
                        $('#oficina').val(oficina);
                        $('#cliente').trigger('change'); 
                    });
            }).fail(function (res) {
                document.getElementById('datSeries').innerHTML = "";
                document.getElementById('datSeries').style = 'display:none';
                $('#cliente').val("");
            });
        }
        else{
            $('#cliente').val("");
        }
    }
    function buscarUbicaciones(){
        const cliente=document.getElementById("cliente").value
        const oficina=document.getElementById("oficina").value
        $.get(
            '/equipos/clientes/buscar/ubicaciones',
            { cliente,oficina},
            function (res) {
                let contenido=`<option value="0">Elige una ubicación</option>`;
                res.ubicaciones.forEach(s => {
                    contenido+=`<option value="${s.id}">${s.nombre}</option>`
                });
                document.getElementById('ubicacion').innerHTML=contenido;
        }).fail(function (res) {
            $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    subtitle: '',
                    body: 'Ha ocurrido un error y no se ha podido obtener los datos del cliente',
                });
        });
    }


  function obtenerDato(id){
    $.get(
        '/maestros/autos/obtener',
        {id:id},
        function (respuesta) {
            $('#editarAuto').modal('show');
            document.getElementById('placaEditar').value=respuesta.data.placa;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
            document.getElementById('kilometrajeEditar').value=respuesta.data.kilometraje;
            document.getElementById('idAuto').value=respuesta.data.id;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el puesto";
        document.getElementById('mostrarErroresAutoEditar').innerHTML=descErrores;
        $('#errorsAutoEditar').show();
        return false;
    });
  }
</script>