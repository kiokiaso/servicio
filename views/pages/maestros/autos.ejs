<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Autos</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item active">Autos</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
              <h3 class="card-title">Autos</h3>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="autos">
                  <thead>
                    <tr>
                      <th style="width: 10px">Id</th>
                      <th>Placa</th>
                      <th>Descripción</th>
                      <th>Kilometraje</th>
                      <th>Fecha de creación</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                      <% autos.forEach(auto=>{ %>
                    <tr>
                      <td><%=auto.id%></td>
                      <td><a class="enlaceModificar" onclick="obtenerDato(<%=auto.id%>)"><%=auto.placa%></a></td>
                      <td><%=auto.descripcion%></td>
                      <td><%=auto.kilometraje%></td>
                      <td>
                        <%= new Date(auto.createdAt).toLocaleString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit', 
                            second: '2-digit' 
                        }) %>
                      </td>
                      <td><%
                        if(auto.activo==1){ %>
                            <a class="btn btn-danger"
                                href="/maestros/autos/eliminar/<%=auto.id%>">Desactivar</a>
                        <% }else{ %>
                            <a class="btn btn-success"
                                href="/maestros/autos/activar/<%=auto.id%>">Activar</a>
                        <% } %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
              <div class="card-footer">
                  <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearAuto">
                      Crear Auto
                  </button>
              </div>
            </div>
          <!-- /.card -->
    </section>
</div>


<!-- MODAL CREAR PERMISO -->
<div class="modal fade" id="crearAuto" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearAutoLabel">Crear Auto</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/maestros/autos/crear" method="POST" id="formCrearAuto">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsAuto" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresAuto"></div>
                    </div>
                    
                    <div class="form-group row">
                        <label for="placa" class="col-sm-2 col-form-label">Placa*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="placa" name="placa" placeholder="XYZ-123" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcion" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcion" name="descripcion"  required></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="kilometraje" class="col-sm-2 col-form-label">Kilometraje inicial*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="kilometraje" name="kilometraje" placeholder="0" required>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDITAR PERMISOS -->
<div class="modal fade" id="editarAuto" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editarAutoLabel">Editar auto</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/maestros/autos/actualizar" method="POST" id="formEditarAuto">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsAutoEditar" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresAutoEditar"></div>
                    </div>
                    <div class="form-group row">
                        <label for="placaEditar" class="col-sm-2 col-form-label">Placa*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="placaEditar" name="placaEditar" placeholder="XYZ-123" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcionEditar" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcionEditar" name="descripcionEditar"  required></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="kilometrajeEditar" class="col-sm-2 col-form-label">Kilometraje inicial*</label>
                        <div class="col-sm-10">
                            <input type="number" class="form-control" id="kilometrajeEditar" name="kilometrajeEditar" placeholder="0" required>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Editar</button>
                <input type="text" class="form-control d-none" id="idAuto" name="idAuto" placeholder="" required>
                </form>
            </div>
        </div>
    </div>
</div>
<%- partial('../../partials/scripts/comun')%>
