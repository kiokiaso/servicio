<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Rutas</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="#">Admin</a></li>
                        <li class="breadcrumb-item active">Rutas</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
        <div class="card">
            <div class="card-header">
              <h3 class="card-title">Rutas</h3>
            </div>
            <!-- /.card-header -->
            <!-- /.card-header -->
            <div class="card-body p-2">
                <table class="display table table-bordered table-striped w-100" id="rutas">
                  <thead>
                    <tr>
                      <th style="width: 10px">Id</th>
                      <th>Código</th>
                      <th>Nombre</th>
                      <th>Descripción</th>
                      <th>Usuario</th>
                      <th>Fecha de creación</th>
                      <th>Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                      <% rutas.forEach(ruta=>{ %>
                    <tr>
                      <td><%=ruta.id%></td>
                      <td><a class="enlaceModificar" onclick="obtenerDato(<%=ruta.id%>)"><%=ruta.codigo%></a></td>
                      <td><%=ruta.nombre%></td>
                      <td><%=ruta.descripcion%></td>
                      <td><%=ruta.usuario.nombre%></td>
                      <td>
                        <%= new Date(ruta.createdAt).toLocaleString('es-ES', { 
                            day: '2-digit', 
                            month: '2-digit', 
                            year: 'numeric', 
                            hour: '2-digit', 
                            minute: '2-digit', 
                            second: '2-digit' 
                        }) %>
                      </td>
                      <td><%
                        if(ruta.activo==1){ %>
                            <a class="btn btn-danger"
                                href="/maestros/rutas/eliminar/<%=ruta.id%>">Desactivar</a>
                        <% }else{ %>
                            <a class="btn btn-success"
                                href="/maestros/rutas/activar/<%=ruta.id%>">Activar</a>
                        <% } %>
                      </td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <!-- /.card-body -->
              <div class="card-footer">
                  <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#crearRuta">
                      Crear Ruta
                  </button>
              </div>
            </div>
          <!-- /.card -->
    </section>
</div>


<!-- MODAL CREAR PERMISO -->
<div class="modal fade" id="crearRuta" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="crearRutaLabel">Crear Permiso</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/maestros/rutas/crear" method="POST" id="formCrearRuta">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsRuta" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresRuta"></div>
                    </div>
                    
                    <div class="form-group row">
                        <label for="codigo" class="col-sm-2 col-form-label">Código*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="codigo" name="codigo" placeholder="123" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" placeholder="Norte" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcion" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcion" name="descripcion" required></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="usuario" class="col-sm-2 col-form-label">Colaborador asignado*</label>
                        <div class="col-sm-10">
                            <select class="form-control" name="usuario" id="usuario" >
                                <% usuarios.forEach(usuario=>{ %>
                                  <option value="<%=usuario.id%>"><%=usuario.nombre%></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Crear</button>
                </form>
            </div>
        </div>
    </div>
</div>
<!-- MODAL EDITAR PERMISOS -->
<div class="modal fade" id="editarRuta" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editarRutaLabel">Editar auto</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" action="/maestros/rutas/actualizar" method="POST" id="formEditarRuta">
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsRutaEditar" style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                            <div id="mostrarErroresRutaEditar"></div>
                    </div>
                    <div class="form-group row">
                        <label for="codigoEditar" class="col-sm-2 col-form-label">Código*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="codigoEditar" name="codigoEditar" placeholder="123" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="nombreEditar" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombreEditar" name="nombreEditar" placeholder="Norte" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="descripcionEditar" class="col-sm-2 col-form-label">Descripción*</label>
                        <div class="col-sm-10">
                            <textarea type="text" class="form-control" id="descripcionEditar" name="descripcionEditar"  required></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="usuarioEditar" class="col-sm-2 col-form-label">Colaborador asignado*</label>
                        <div class="col-sm-10">
                            <select class="form-control" name="usuarioEditar" id="usuarioEditar" >
                                <% usuarios.forEach(usuario=>{ %>
                                  <option value="<%=usuario.id%>"><%=usuario.nombre%></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" class="btn btn-primary">Editar</button>
                <input type="text" class="form-control d-none" id="idRuta" name="idRuta" placeholder="" required>
                </form>
            </div>
        </div>
    </div>
</div>
<%- partial('../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
