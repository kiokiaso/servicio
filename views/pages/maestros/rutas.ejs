<script>
    $(document).ready(function () {
        var t = $('#rutas').DataTable({
            columnDefs: [
                {
                    searchable: true,
                    orderable: true,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
                //t.buttons().container().appendTo('#inventario_wrapper .col-md-6:eq(0)');   
    });
  function obtenerDato(id){
    $.get(
        '/maestros/rutas/obtener',
        {id:id},
        function (respuesta) {
            $('#editarRuta').modal('show');
            document.getElementById('codigoEditar').value=respuesta.data.codigo;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
            document.getElementById('nombreEditar').value=respuesta.data.nombre;
            document.getElementById('usuarioEditar').value=respuesta.data.usuario;
            document.getElementById('idRuta').value=respuesta.data.id;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el puesto";
        document.getElementById('mostrarErroresRutaEditar').innerHTML=descErrores;
        $('#errorsRutaEditar').show();
        return false;
    });
  }
</script>