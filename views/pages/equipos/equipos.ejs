<script src="/plugins/datatables-buttons/js/buttons.colVis.min.js"></script>-->
<script>
    $(document).ready(function () {
        var table = $('#equipos').DataTable({
            stateSave: true,
            
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
    });

    $("#formAgregarEquipo").on('submit', function(e){
            e.preventDefault();
                $.ajax({
                    type: 'POST',
                    url: '/clientes/equipo/agregar',
                    data: new FormData(this),
                    contentType: false,
                    cache: false,
                    processData:false,
                    success: function(){
                    ob = $.parseJSON(arguments[2].responseText);
                        if(ob.resp==1){
                            $(document).Toasts('create', {
                                class: 'bg-success',
                                title: 'Correcto',
                                subtitle: 'exito',
                                body: `Se ha agregado de forma correcta el equipo ${ob.equipo.numeroserie}`,
                            })
                            setTimeout(() => {
                                location.reload();
                            },1000);
                        }
                        else{
                            $(document).Toasts('create', {
                                class: 'bg-danger',
                                title: 'Error',
                                subtitle: '',
                                body: ob.mensaje,
                            });
                        }
                        $('#crearEquipo').modal('hide');
                    }
                });
    });

    function buscarSeries(){
        var numero = document.getElementById("numeroserie").value;
        var oficina = document.getElementById("oficinaEquipo").value;
        var contenido="<div><strong>Clic a la serie para elegirla</strong></div>";
        if(numero.length>2&&oficina!=""){
            $.get(
                '/almacen/series/buscar',
                { numero: numero,oficina },
                function (res) {
                    res.series.forEach(s => {
                        contenido = contenido + `<div style="cursor:pointer"><a class="suggest-element" data="${s.id}" serie="${s.serie}"  id="${s.id}" marca="${s.articulo.marca}" modelo="${s.articulo.modelo}" articulo="${s.articulo.id}" descripcion="${s.articulo.descripcion}" tipocolor="${s.articulo.tipocolor}" tamano="${s.articulo.tamano}" >${s.serie}</a></div>`;

                    });
                    $('#datSeries').fadeIn(1000).html(contenido);
                    $('.suggest-element').on('click', function () {
                                //Obtenemos la id unica de la sugerencia pulsada
                        var id = $(this).attr('id');
                        var marca = $(this).attr('marca');
                        var modelo = $(this).attr('modelo');
                        var articulo = $(this).attr('articulo');
                        var descripcion = $(this).attr('descripcion');
                        var tipocolor = $(this).attr('tipocolor');
                        var tamano = $(this).attr('tamano');
                        var serie = $(this).attr('serie');
                        $('#numeroserie').val($('#' + id).attr('data'));
                                    //Hacemos desaparecer el resto de sugerencias
                        document.getElementById('datSeries').innerHTML = "";
                        document.getElementById('datSeries').style = 'display:none';
                                    //alert('Has seleccionado el '+id+' '+$('#'+id).attr('data'));
                        $('#serieId').val(id);
                        $('#articuloId').val(articulo);
                        $('#marca').val(marca);
                        $('#modelo').val(modelo);
                        $('#descripcion').val(descripcion);
                        $('#tipocolor').val(tipocolor);
                        $('#tamano').val(tamano);
                        $('#numeroserie').val(serie);
                        //$('#idArticulo').trigger('change'); 
                    });
            }).fail(function (res) {
                document.getElementById('datSeries').innerHTML = "";
                document.getElementById('datSeries').style = 'display:none';
                $('#serieId').val("");
            });
        }
        else{
            if(oficina==""){
                $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    body: `Para buscar la serie, primero debes elegir el cliente`,
                })
            }
            document.getElementById('datSeries').innerHTML = "";
            document.getElementById('datSeries').style = 'display:none';
            $('#serieId').val("");
        }
    }
    function buscarCliente(){
        var numero = document.getElementById("cliente").value;
        var contenido="<div><strong>Clic al cliente para elegirlo</strong></div>";
        if(numero.length>2){
            $.get(
                '/equipos/clientes/buscar',
                { cliente: numero},
                function (res) {
                    res.clientes.forEach(s => {
                        contenido = contenido + `<div style="cursor:pointer"><a class="suggest-element" data="${s.id}" nombre="${s.razonsocial}"  id="${s.id}" oficina="${s.oficina.id}">${s.razonsocial}</a></div>`;

                    });
                    $('#datClientes').fadeIn(1000).html(contenido);
                    $('.suggest-element').on('click', function () {
                                //Obtenemos la id unica de la sugerencia pulsada
                        var id = $(this).attr('id');
                        var nombre = $(this).attr('nombre');
                        var oficina = $(this).attr('oficina');
                        $('#cliente').val($('#' + id).attr('data'));
                                    //Hacemos desaparecer el resto de sugerencias
                        document.getElementById('datClientes').innerHTML = "";
                        document.getElementById('datClientes').style = 'display:none';
                                    //alert('Has seleccionado el '+id+' '+$('#'+id).attr('data'));
                        $('#cliente').val(nombre);
                        $('#clienteEquipo').val(id);
                        $('#oficinaEquipo').val(oficina);
                        $('#clienteEquipo').trigger('change'); 
                    });
            }).fail(function (res) {
                document.getElementById('datSeries').innerHTML = "";
                document.getElementById('datSeries').style = 'display:none';
                $('#clienteEquipo').val("");
            });
        }
        else{
            document.getElementById('datSeries').innerHTML = "";
            document.getElementById('datSeries').style = 'display:none';
            $('#clienteEquipo').val("");
        }
    }
    function buscarUbicaciones(){
        const cliente=document.getElementById("clienteEquipo").value
        const oficina=document.getElementById("oficinaEquipo").value
        $.get(
            '/equipos/clientes/buscar/ubicaciones',
            { cliente,oficina},
            function (res) {
                let contenido=``;
                res.ubicaciones.forEach(s => {
                    contenido+=`<option value="${s.id}">${s.nombre}</option>`
                });
                document.getElementById('ubicacionEquipo').innerHTML=contenido;
        }).fail(function (res) {
            $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    subtitle: '',
                    body: 'Ha ocurrido un error y no se ha podido obtener los datos del cliente',
                });
        });
    }


  function obtenerDato(id){
    $.get(
        '/maestros/autos/obtener',
        {id:id},
        function (respuesta) {
            $('#editarAuto').modal('show');
            document.getElementById('placaEditar').value=respuesta.data.placa;
            document.getElementById('descripcionEditar').value=respuesta.data.descripcion;
            document.getElementById('kilometrajeEditar').value=respuesta.data.kilometraje;
            document.getElementById('idAuto').value=respuesta.data.id;
        }
    ).fail(function(res){
        descErrores=descErrores+"No se ha encontrado el puesto";
        document.getElementById('mostrarErroresAutoEditar').innerHTML=descErrores;
        $('#errorsAutoEditar').show();
        return false;
    });
  }
</script>