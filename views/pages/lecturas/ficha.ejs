    function guardarEquipos(){
        let datos = [];
        let lecturas=document.getElementById('lecturas').value;
        $('.check-item:checked').each(function() {
            let fila = $(this).closest('tr');
            datos.push({ id: fila.data('id') });
        });
        if(datos.length==0){
            return $(document).Toasts('create', {
                class: 'bg-danger',
                title: 'Error',
                body: `Debes seleccionar por lo menos un equipo`,
            })
        }
        $.post(
            '/lecturas/agregar-equipo',
            {equipos:datos,lecturas},
            function (res) {
                if(res.resp==1){
                    window.location.href = `/lecturas/${res.lectura.id}`;
                }
            }).fail(function (res) {
               $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    body: `Se ha producido un error al momento de agregar más equipos`,
                })
            });
    };
    function modalAgregarEquipo(id){
        $.get(
                '/lecturas/equipo/datos',
                {id:id},
                function (respuesta) {
                    if(respuesta.resp==0){
                        $(document).Toasts('create', {
                            class: 'bg-danger',
                            title: 'Error',
                            subtitle: '',
                            body:respuesta.message,
                        });
                    }else{
                        $('#agregarEquipo').modal('show');
                        const tbody = document.querySelector('#tablaEquipos tbody');
                        let contenido=``;
                        respuesta.equipos.forEach(s => {
                            contenido = contenido + `
                                <tr class="fila-articulo" data-id="${s.id}">
                                    <td><input type="checkbox"  class="check-item"></td>
                                    <td>${s.numeroserie}</td>
                                    <td>${s.descripcion}</td>
                                    <td>${s.marca}</td>
                                    <td>${s.modelo}</td>
                                </tr>
                            `;
                        });
                        tbody.innerHTML=contenido;
                    }
                   
                }
            ).fail(function(res){
                $(document).Toasts('create', {
                    class: 'bg-danger',
                    title: 'Error',
                    subtitle: '',
                    body: 'Ha ocurrido un error y no se han podido obtener los equipos',
                });
            });
    }

