<link rel="stylesheet" href="/plugins/fontawesome-free/css/all.min.css">
<!-- DataTables -->
 <link rel="stylesheet" href="/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
<link rel="stylesheet" href="/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
<link rel="stylesheet" href="/js/datatables/fixedColumns.dataTables.min.css">

<link rel="stylesheet" href="/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">


<style>
    .card-info-header {
        border-left: 4px solid #007bff;
    }
    .status-pill {
        font-size: 0.8rem;
        padding: 0.4rem 1rem;
        border-radius: 50px;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }
    .card {
        border-radius: 12px;
        border: none;
    }
    .nav-tabs-custom .nav-link {
        border: none;
        color: #6c757d;
        font-weight: 600;
        padding: 1rem 1.5rem;
    }
    .nav-tabs-custom .nav-link.active {
        color: #007bff;
        border-bottom: 3px solid #007bff;
        background: transparent;
    }
</style>

<div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h2 class="font-weight-bold text-dark mb-0"><i class="nav-icon bi-speedometer2"></i><%=lectura.nombre%> </h2>
                   
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
                        <li class="breadcrumb-item"><a href="/lecturas">Lecturas</a></li>
                        <li class="breadcrumb-item active">Ficha</li>
                    </ol>
                </div>
            </div>
        </div><!-- /.container-fluid -->
    </section>
    <% flash.get('mensaje').forEach(function (msg){ %>
        <div class="alert alert-info text-center" role="alert">
            <%=msg%>
        </div>
    <% }) %>
    <section class="content">
<div class="container-fluid  bg-light min-vh-100">
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm mb-4 card-info-header">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small font-weight-bold mb-3">Datos del Cliente</h6>
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mr-3" style="width: 45px; height: 45px;">
                            <i class="fas fa-user border-0"></i>
                        </div>
                        <div>
                            <p class="mb-0 font-weight-bold"><%= lectura.cliente.razonsocial %></p>
                            <small class="text-muted">ID Cliente: #<%= lectura.cliente.codigo %></small>
                        </div>
                        <div>
                                <% if(lectura.ubicacion&&lectura.ubicacion.oficinaAtencion===oficinaElegida.id){ %>
                                    <span class="badge badge-danger">Póliza entre exi <%=lectura.oficina.nombre%></span> 
                                <% }  %>
                        </div>
                    </div>
                    <hr>
                    <div class="mb-3">
                        <label class="text-muted small mb-1 d-block">Ubicación</label>
                        <p class="font-weight-500"><i class="fas fa-map-marker-alt text-danger mr-1"></i> <%= lectura.ubicacion.nombre %></p>
                    </div>
                    <div class="row border-top mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1 d-block">Periodicidad</label>
                            <span class="badge badge-soft-primary"><%= lectura.periodicidad %></span>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1 d-block">Agrupado</label>
                            <span class="badge <%= lectura.agruparequipos ? 'badge-success' : 'badge-secondary' %>">
                                <%= lectura.agruparequipos ? 'Sí' : 'No' %>
                            </span>
                        </div>
                    </div>
                    <div class="row border-top ">
                        <div class="col-6">
                            <label class="text-muted small mb-1 d-block">Fecha de inicio</label>
                           <span class="badge badge-soft-primary"><%= new Date(lectura.inicio).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' })  %></span>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1 d-block">Fecha de fin</label>
                           <span class="badge badge-soft-primary"><%= new Date(lectura.fin).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' })  %></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="p-3 border-bottom">
                        <h6 class="mb-0 font-weight-bold">Observaciones</h6>
                    </div>
                    <div class="p-3">
                        <p class="text-muted small mb-0">
                            <%= lectura.observaciones || 'Sin observaciones registradas.' %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="row justify-content-end mb-4">
                <div class="col-auto"> <div class="btn-group shadow-sm">
                        <button class="btn btn-white bg-success border" onclick="modalAgregarEquipo(<%=lectura.id%>)">
                            <i class="bi bi-printer-fill mr-1"></i> Agregar Equipo
                        </button>
                        <button class="btn btn-white bg-warning border" data-toggle="modal" data-target="#editarLectura">
                            <i class="fas fa-edit mr-1"></i> Editar
                        </button>
                        <button class="btn btn-info" data-toggle="modal" data-target="#agregarAsistencia">
                            <i class="fas fa-calendar-check mr-1"></i> Agregar 1 Asistencia
                        </button>
                        <%
                            let inicioTs = new Date(lectura.inicio).getTime();
                            let finTs = new Date(lectura.fin).getTime();
                            
                            // El botón se habilita solo si Inicio < Fin
                            if(inicioTs < finTs){
                        %>
                        <button class="btn btn-primary" onclick="generarAsistencias(<%=lectura.id%>)">
                            <i class="fas fa-calendar-plus mr-1"></i> Programar Asistencia
                        </button>
                        <% }else{ %>
                            <div class="alert alert-info" role="alert">
                                <i class="bi bi-x-circle-fill mr-2"></i> <!-- Icono opcional -->
                                la fecha de inicio debe ser menor a la de fin para poder crear las asistencias
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-header bg-white p-0">
                    <ul class="nav nav-tabs nav-tabs-custom border-0" id="myTab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="equipos-tab" data-toggle="tab" href="#equipos" role="tab">
                                <i class="fas fa-microchip mr-2"></i>Equipos Vinculados
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="asistencias-tab" data-toggle="tab" href="#asistencias" role="tab">
                                <i class="fas fa-clock mr-2"></i>Historial de Asistencias
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-0">
                    <div class="tab-content" id="myTabContent">
                        <div class="tab-pane fade show active" id="equipos" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light text-muted small text-uppercase">
                                        <tr>
                                            <th class="border-0 pl-4">Descripción</th>
                                            <th class="border-0">Nº Serie</th>
                                            <th class="border-0 text-right pr-4">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% lectura.equiposAsignados.forEach(ea => { %>
                                        <tr>
                                            <td class="pl-4 align-middle font-weight-bold"><%= ea.equipo.descripcion %></td>
                                            <td class="align-middle"><code><%= ea.equipo.numeroserie %></code></td>
                                            <td class="text-right pr-4">
                                                <button class="btn btn-sm btn-link text-danger btnEliminarEquipo" data-id="<%=ea.id%>" title="Quitar equipo" >
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="asistencias" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light text-muted small text-uppercase">
                                        <tr>
                                            <th class="border-0 pl-4">Fecha Prevista</th>
                                            <th class="border-0">Estado</th>
                                            <th class="border-0">Descripción</th>
                                            <th class="border-0">Aviso</th>
                                            <th class="border-0 text-right pr-4">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% lectura.asistencias.forEach(ast => { %>
                                        <tr>
                                            <td class="pl-4 align-middle">
                                                <%= new Date(ast.fechaprevista).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' }) %>
                                                
                                            </td>
                                            <td class="align-middle">
                                                <span class="status-pill badge <%= ast.estado === 'pendiente' ? 'badge-warning text-dark' : 'badge-success' %>">
                                                    <%= ast.estado %>
                                                </span>
                                            </td>
                                            <td class="align-middle">
                                                <span class="text-muted small italic"><%=ast.descripcion%></span>
                                            </td>
                                            <td class="align-middle">
                                                <% if(ast.avisos.length>0) {
                                                    ast.avisos.forEach(av => {  %>
                                                        <a href="/avisos/<%= av.id %>" class="badge badge-info">#<%= av.folio %></a>
                                                   <%  })
                                                 } else { %>
                                                    <span class="text-muted small italic">Sin aviso</span>
                                                <% } %>
                                            </td>
                                            <td class="text-right pr-4">
                                                <%if(ast.estado=='pendiente'){%>
                                                <button class="btn btn-sm btn-link text-warning btnEditarAsistencia" data-id="<%=ast.id%>" title="Editar Asistencia" >
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button class="btn btn-sm btn-link text-danger btnEliminarAsistencia" data-id="<%=ast.id%>" title="Eliminar Asistencia" >
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                <%}%>
                                            </td>
                                        </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    </section>
</div>

<!-- MODAL EDITAR LECTURA -->
<div class="modal fade" id="editarLectura" data-backdrop="static" tabindex="-1" aria-labelledby="exampleModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="agregarEquipoLabel">Editar Lectura</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form class="form-horizontal" >
                    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorsEquipo"
                        style="display: none;">
                        <button type="button" class="close" data-dismiss="alert"
                            aria-label="Close"><span>&times;</span></button>
                        <div id="mostrarErroresEquipo"></div>
                    </div>
                    <div class="form-group row">    
                        <label for="nombre" class="col-sm-2 col-form-label">Nombre*</label>
                        <div class="col-sm-10">
                            <input type="text" class="form-control" id="nombre" name="nombre" required value="<%=lectura.nombre%>">
                        </div>
                    </div>
                    <div class="form-group row">    
                        <label for="inicio" class="col-sm-2 col-form-label">Fecha de inicio*</label>
                        <div class="col-sm-10">
                            <input type="date" class="form-control" id="inicio" name="inicio" required >
                        </div>
                    </div>
                    <div class="form-group row">    
                        <label for="fin" class="col-sm-2 col-form-label">Fecha de fin*</label>
                        <div class="col-sm-10">
                            <input type="date" class="form-control" id="fin" name="fin" required >
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="agrupar" class="col-sm-2 col-form-label">Agrupar elementos*</label>
                        <div class="col-sm-10">
                            <select name="agrupar" id="agrupar" class="form-control">
                                <option value="true" <%=lectura.agrupar==true?'selected':''%>>Si</option>
                                <option value="false" <%=lectura.agrupar==false?'selected':''%>>No</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="observaciones" class="col-sm-2 col-form-label">Observaciones*</label>
                        <div class="col-sm-10">
                            <textarea name="observaciones" id="observaciones" rows="3" class="form-control"><%=lectura.observaciones%></textarea>
                        </div>
                    </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="guardarDatos()">Editar</button>
                <input type="text" class="d-none" name="idLectura" id="idLectura" value="<%=lectura.id%>">
                </form>
            </div>
        </div>
    </div>
</div>
