<%- partial('../../partials/scripts/comun')%>
<!-- DataTables  & Plugins -->
<script src="/plugins/datatables/jquery.dataTables.min.js"></script>
<script src="/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<script src="/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
<script src="/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
<script src="/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
<script src="/js/datatables/dataTables.fixedColumns.min.js"></script>
<!-- SweetAlert2 -->
<script src="/plugins/sweetalert2/sweetalert2.min.js"></script>
<script>
    $(document).ready(function () {
        document.getElementById('btn-agregar-serie').addEventListener('click', function() {
            let input = document.createElement('input');
            input.type = 'text';
            input.name = 'series[]';
            input.className = 'form-control';
            document.getElementById('lista-series').appendChild(input);
        });
        var table = $('#articulos').DataTable({
            "processing":true,
            "serverSide":true,
            "ajax":{
                "url":"/almacen/articulos/tabla",
                "type":"GET"
            },
            rowId: 'id',
            stateSave: true,
            columns: [
                { data:  null,
                    render:function(data,type,row){
                        return `<a href="/almacen/articulos/${row.id}">
                                ${row.codigo}
                            </a>`;
                    }},
                { data: 'descripcion'},
                { data: 'marca'},
                { data: 'modelo' },
                { data: 'tipo' },
                { data: 'garantia' },
                { data: 'preciopublico'},
            ],
            columnDefs: [
                {
                    searchable: false,
                    orderable: false,
                    targets: 0,
                },
            ],
            scrollX:true,
            scrollCollapse:true,
            fixedColumns:{leftColumns:2},
            order: [[0, 'asc']],
        });
    });
    function generarAsistencias(id){
        Swal.fire({
            title: '¿Deseas generar las asistencias?',
            text: "Debes tener en cuenta que si hay asistencias creadas para esta toma de lectura, estas se van a eliminar para poder generar las nuevas",
            icon: 'question',
            input: 'textarea', // Cambia a 'text' si quieres una sola línea
            inputValue: 'Toma de lectura',
            inputAttributes: {
                'aria-label': 'Escribe tu descripción',
                'rows': 3,
                'id':'descripcionLectura'
            },
            showCancelButton: true,
            confirmButtonColor: '#3085d6', // Azul profesional
            cancelButtonColor: '#6c757d', // Gris neutro
            confirmButtonText: '<i class="fas fa-check"></i> Acepto',
            cancelButtonText: 'Cancelar',
            reverseButtons: true,
            allowOutsideClick: false 
        }).then((result) => {
            if (result.isConfirmed) {
                // Aquí ejecutas tu lógica de AJAX
                Swal.fire({
                    title: 'Generando asistencias...',
                    html: 'Por favor espere un momento.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
                let desc=result.value
                $.post(
                    '/lecturas/asistencias/generar',
                    {id:id,descripcion:desc},
                    function (res) {
                        Swal.fire({
                            title: '¡Operación Exitosa!',
                            text: `Se han generado ${res.cantidad} asistencias correctamente.`,
                            icon: 'success',
                            confirmButtonText: 'Entendido'
                        }).then(() => {
                            location.reload(); // Recargamos para ver los cambios en la tabla
                        });
                        
                    }).fail(function (res) {
                        Swal.fire('Error', 'No se pudieron generar las asistencias. Intente de nuevo.', 'error');
                    });
                //alert(`Has elegido que si: ${desc}`)
            }
        });
        /**/
    };
    function agregarDatosAsistencia(){
        let datos = [];
        let lecturas=document.getElementById('idLectura').value;
        let descripcion=document.getElementById('descripcionAgregar').value;
        let fechaprevista=document.getElementById('fechaprevistaAgregar').value;
        
        $.post(
            '/lecturas/asistencias/agregar',
            {id:lecturas,descripcion,fechaprevista},
            function (res) {
                $(document).Toasts('create', {
                    class: 'bg-success',
                    title: 'Error',
                    body: `Se ha agregado la asistencia de forma correcta`,
                })
                setTimeout(()=>{
                    window.location.href = `/lecturas/${lecturas}`;    
                },1000)
                   
