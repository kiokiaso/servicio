  /* Contenedor principal de todas las ventanas */
.chat-bar-container {
    position: fixed;
    bottom: 0;
    right: 20px;
    display: flex;
    align-items: flex-end;
    z-index: 9999;
    gap: 10px;
}

/* Estilo de la ventana de chat */
.chat-window {
    width: 300px;
    transition: all 0.3s ease;
    border-radius: 10px 10px 0 0 !important;
}

/* Estado minimizado */
.chat-window.minimized {
    height: 45px;
    overflow: hidden;
}


.chat-controls button {
    background: none;
    border: none;
    color: white;
    padding: 0 5px;
    cursor: pointer;
    font-size: 14px;
}

  .chat-bar-container > * { pointer-events: auto; }

  /* Burbujas de Mensaje */
  .msg-bubble {
    padding: 8px 12px;
    border-radius: 18px;
    margin-bottom: 5px;
    max-width: 85%;
    clear: both;
    position: relative;
    font-size: 13px;
  }

  .msg-enviado {
    background-color: #0084ff;
    color: white;
    float: right;
    border-bottom-right-radius: 4px;
  }

  .msg-recibido {
    background-color: #e4e6eb;
    color: black;
    float: left;
    border-bottom-left-radius: 4px;
  }
