    <%- partial('../partials/estilos')%>
    <style>
      .chat-bar-container {
          position: fixed;
          bottom: 0;
          right: 20px;
          display: flex;
          align-items: flex-end;
          gap: 10px;
          z-index: 9999;
      }

      /* Ventana de chat */
      .chat-window {
          width: 280px;
          height: 400px;
          display: flex;
          flex-direction: column;
          margin-bottom: 0 !important;
      }

      /* Estado minimizado */
      .chat-window.minimized {
          height: 45px;
          overflow: hidden;
      }

      /* Header */
      .chat-controls button {
          background: none;
          border: none;
          color: white;
          cursor: pointer;
      }

      /* Cuerpo del chat */
      .chat-body {
          flex: 1;
          display: flex;
          flex-direction: column;
          overflow: hidden; /* 👈 importante */
      }

      /* Área de mensajes */
      .chat-history-area {
          flex: 1;
          overflow-y: auto;
          display: flex;
          flex-direction: column;
          padding: 10px;
          background: #fff;
      }

      /* Input */
      .chat-body .card-footer {
          flex-shrink: 0;
          background: #fff;
      }

      /* Burbujas */
      .msg-bubble {
          padding: 8px 12px;
          border-radius: 18px;
          margin: 5px 8px;
          max-width: 75%;
          font-size: 13px;
      }

      /* Enviado */
      .msg-enviado {
          background-color: #0084ff;
          color: white;
          align-self: flex-end;
      }

      /* Recibido */
      .msg-recibido {
          background-color: #e4e6eb;
          color: black;
          align-self: flex-start;
      }
    </style>
  </head>

