}


  /* Punto Online */
  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 5px;
  }
  .status-online { background-color: #31a24c; }
  .status-offline { background-color: #bdc3c7; }
    </style>
